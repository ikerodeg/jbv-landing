---
import Icon from "./ui/Icon.astro";
---

<section id="contacto" class="section contact" aria-label="Contacto">
  <div class="section-inner">
    <p class="section-eyebrow reveal">Contacto</p>
    <h2 class="section-title reveal">
      Hablemos de su <span class="accent">próximo proyecto</span>
    </h2>
    <p class="section-lead reveal">
      Cuéntenos qué necesita y le asesoraremos sin compromiso. La mejor grúa
      para su empresa puede estar en Alemania esperándole.
    </p>

    <div class="contact-grid">
      <!-- Left: Direct contact -->
      <div class="contact-info reveal">
        <h3>Contacto Directo</h3>
        <p>
          Preferimos hablar con usted directamente. Así entendemos mejor sus
          necesidades y podemos ofrecerle la solución más adecuada para su
          empresa.
        </p>

        <div class="contact-methods">
          <a
            href="https://wa.me/34600000000"
            class="contact-cta"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Enviar mensaje por WhatsApp"
          >
            <div class="cta-ico wa" aria-hidden="true">
              <Icon name="whatsapp" />
            </div>
            <div class="cta-label">
              <strong>WhatsApp</strong>
              <span>Respuesta rápida</span>
            </div>
          </a>

          <a
            href="tel:+34600000000"
            class="contact-cta"
            aria-label="Llamar por teléfono"
          >
            <div class="cta-ico ph" aria-hidden="true">
              <Icon name="phone" />
            </div>
            <div class="cta-label">
              <strong>+34 600 000 000</strong>
              <span>Llamada directa</span>
            </div>
          </a>
        </div>
      </div>

      <!-- Right: Form -->
      <div class="reveal reveal-delay-2">
        <form
          class="contact-form"
          id="contact-form"
          action="#"
          method="post"
          aria-label="Formulario de consulta"
          novalidate
        >
          <div class="form-row">
            <div class="form-field">
              <label for="nombre">Nombre *</label>
              <input
                type="text"
                id="nombre"
                name="nombre"
                placeholder="Su nombre"
                required
                autocomplete="name"
                inputmode="text"
              />
            </div>
            <div class="form-field">
              <label for="empresa">Empresa *</label>
              <input
                type="text"
                id="empresa"
                name="empresa"
                placeholder="Nombre de su empresa"
                required
                autocomplete="organization"
              />
            </div>
          </div>

          <div class="form-row">
            <div class="form-field">
              <label for="telefono">Teléfono *</label>
              <input
                type="tel"
                id="telefono"
                name="telefono"
                placeholder="+34 600 000 000"
                required
                autocomplete="tel"
                inputmode="tel"
              />
            </div>
            <div class="form-field">
              <label for="email">Email</label>
              <input
                type="email"
                id="email"
                name="email"
                placeholder="correo@empresa.com"
                autocomplete="email"
                inputmode="email"
              />
            </div>
          </div>

          <div class="form-field">
            <label for="mensaje">Mensaje / Tipo de grúa que busca</label>
            <textarea
              id="mensaje"
              name="mensaje"
              rows="5"
              placeholder="Describa qué tipo de grúa autopropulsada necesita: tonelaje, marca preferida, presupuesto orientativo, plazos..."
            ></textarea>
          </div>

          <div class="form-privacy">
            <input type="checkbox" id="privacidad" name="privacidad" required />
            <label for="privacidad">
              He leído y acepto la <a href="/privacidad"
                >Política de Privacidad</a
              > de JBV. Mis datos serán tratados para gestionar mi consulta.
            </label>
          </div>

          <!-- Honeypot anti-spam -->
          <input
            type="text"
            name="_honey"
            style="display:none"
            tabindex="-1"
            autocomplete="off"
            aria-hidden="true"
          />

          <div class="form-submit">
            <button type="submit" class="btn btn-primary">
              <Icon name="send" />
              Enviar Consulta
            </button>
          </div>
        </form>

        <div class="form-success" id="form-success" hidden aria-live="polite">
          <h3>¡Mensaje Enviado!</h3>
          <p>
            Gracias por contactarnos. Le responderemos lo antes posible,
            normalmente en menos de 24 horas.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById(
    "contact-form",
  ) as HTMLFormElement | null;
  const success = document.getElementById("form-success");

  form?.addEventListener("submit", (e) => {
    e.preventDefault();
    // In production: connect to FormSubmit, Netlify Forms, or email service
    form.hidden = true;
    if (success) success.hidden = false;
  });
</script>

<style>
  .contact {
    background: var(--navy-800);
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1.3fr;
    gap: 4rem;
    align-items: start;
  }

  .contact-info h3 {
    font-family: var(--font-condensed);
    font-size: 1.3rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    color: var(--white);
    margin-block-end: 1rem;
  }

  .contact-info > p {
    font-size: 0.95rem;
    color: var(--white-50);
    line-height: 1.7;
    margin-block-end: 2rem;
  }

  .contact-methods {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }

  .contact-cta {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding-block: 1rem;
    padding-inline: 1.25rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--r-md);
    text-decoration: none;
    transition: all var(--dur) var(--ease);
  }

  .contact-cta:hover {
    border-color: oklch(0.73 0.19 52 / 0.3);
    transform: translateX(4px);
  }

  .cta-ico {
    inline-size: 44px;
    block-size: 44px;
    border-radius: var(--r-md);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .cta-ico.wa {
    background: oklch(0.63 0.18 155 / 0.15);
    color: var(--green-500);
  }

  .cta-ico.ph {
    background: oklch(0.73 0.19 52 / 0.15);
    color: var(--orange-500);
  }

  .cta-ico svg {
    inline-size: 22px;
    block-size: 22px;
  }

  .cta-label strong {
    display: block;
    font-family: var(--font-condensed);
    font-weight: 700;
    font-size: 0.95rem;
    color: var(--white);
    margin-block-end: 0.15rem;
  }

  .cta-label span {
    font-size: 0.82rem;
    color: var(--white-50);
  }

  /* Form */
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .form-field {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .form-field label {
    font-family: var(--font-condensed);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--white-50);
  }

  .form-field input,
  .form-field textarea {
    padding-block: 0.8rem;
    padding-inline: 1rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--r-md);
    color: var(--white);
    font-family: var(--font-body);
    font-size: 0.95rem;
    transition:
      border-color var(--dur) var(--ease),
      box-shadow var(--dur) var(--ease);
    outline: none;
    -webkit-appearance: none;
  }

  .form-field input::placeholder,
  .form-field textarea::placeholder {
    color: var(--navy-400);
  }

  .form-field input:focus,
  .form-field textarea:focus {
    border-color: var(--orange-500);
    box-shadow: 0 0 0 3px oklch(0.73 0.19 52 / 0.12);
  }

  .form-field textarea {
    min-block-size: 130px;
    resize: vertical;
  }

  .form-privacy {
    font-size: 0.8rem;
    color: var(--white-50);
    display: flex;
    gap: 0.5rem;
    align-items: flex-start;
  }

  .form-privacy input[type="checkbox"] {
    margin-block-start: 2px;
    accent-color: var(--orange-500);
    flex-shrink: 0;
  }

  .form-privacy a {
    color: var(--orange-400);
    text-decoration: underline;
  }

  .form-success {
    text-align: center;
    padding-block: 3rem;
    padding-inline: 2rem;
    background: var(--surface);
    border: 1px solid oklch(0.73 0.19 52 / 0.2);
    border-radius: var(--r-lg);
  }

  .form-success h3 {
    font-family: var(--font-display);
    font-size: 1.8rem;
    color: var(--orange-500);
    margin-block-end: 0.75rem;
  }

  .form-success p {
    color: var(--white-50);
  }

  @media (max-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .form-row {
      grid-template-columns: 1fr;
    }
  }
</style>
