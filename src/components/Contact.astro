---
---

<section id="contacto" class="section contact" aria-label="Contacto">
  <div class="section-inner">
    <p class="section-eyebrow reveal">Contacto</p>
    <h2 class="section-title reveal">
      Hablemos de su <span class="accent">próximo proyecto</span>
    </h2>
    <p class="section-lead reveal">
      Cuéntenos qué necesita y le asesoraremos sin compromiso.
      La mejor grúa para su empresa puede estar en Alemania esperándole.
    </p>

    <div class="contact-grid">
      <!-- Left: Direct contact -->
      <div class="contact-info reveal">
        <h3>Contacto Directo</h3>
        <p>
          Preferimos hablar con usted directamente. Así entendemos mejor sus necesidades
          y podemos ofrecerle la solución más adecuada para su empresa.
        </p>

        <div class="contact-methods">
          <a
            href="https://wa.me/34600000000"
            class="contact-cta"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Enviar mensaje por WhatsApp"
          >
            <div class="cta-ico wa" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
            </div>
            <div class="cta-label">
              <strong>WhatsApp</strong>
              <span>Respuesta rápida</span>
            </div>
          </a>

          <a href="tel:+34600000000" class="contact-cta" aria-label="Llamar por teléfono">
            <div class="cta-ico ph" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
              </svg>
            </div>
            <div class="cta-label">
              <strong>+34 600 000 000</strong>
              <span>Llamada directa</span>
            </div>
          </a>
        </div>
      </div>

      <!-- Right: Form -->
      <div class="reveal reveal-delay-2">
        <form
          class="contact-form"
          id="contact-form"
          action="#"
          method="post"
          aria-label="Formulario de consulta"
          novalidate
        >
          <div class="form-row">
            <div class="form-field">
              <label for="nombre">Nombre *</label>
              <input
                type="text"
                id="nombre"
                name="nombre"
                placeholder="Su nombre"
                required
                autocomplete="name"
                inputmode="text"
              />
            </div>
            <div class="form-field">
              <label for="empresa">Empresa *</label>
              <input
                type="text"
                id="empresa"
                name="empresa"
                placeholder="Nombre de su empresa"
                required
                autocomplete="organization"
              />
            </div>
          </div>

          <div class="form-row">
            <div class="form-field">
              <label for="telefono">Teléfono *</label>
              <input
                type="tel"
                id="telefono"
                name="telefono"
                placeholder="+34 600 000 000"
                required
                autocomplete="tel"
                inputmode="tel"
              />
            </div>
            <div class="form-field">
              <label for="email">Email</label>
              <input
                type="email"
                id="email"
                name="email"
                placeholder="correo@empresa.com"
                autocomplete="email"
                inputmode="email"
              />
            </div>
          </div>

          <div class="form-field">
            <label for="mensaje">Mensaje / Tipo de grúa que busca</label>
            <textarea
              id="mensaje"
              name="mensaje"
              rows="5"
              placeholder="Describa qué tipo de grúa autopropulsada necesita: tonelaje, marca preferida, presupuesto orientativo, plazos..."
              writingsuggestions="false"
            ></textarea>
          </div>

          <div class="form-privacy">
            <input type="checkbox" id="privacidad" name="privacidad" required />
            <label for="privacidad">
              He leído y acepto la <a href="/privacidad">Política de Privacidad</a> de JBV.
              Mis datos serán tratados para gestionar mi consulta.
            </label>
          </div>

          <!-- Honeypot anti-spam -->
          <input type="text" name="_honey" style="display:none" tabindex="-1" autocomplete="off" aria-hidden="true" />

          <div class="form-submit">
            <button type="submit" class="btn btn-primary">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/>
              </svg>
              Enviar Consulta
            </button>
          </div>
        </form>

        <div class="form-success" id="form-success" hidden aria-live="polite">
          <h3>¡Mensaje Enviado!</h3>
          <p>Gracias por contactarnos. Le responderemos lo antes posible, normalmente en menos de 24 horas.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const success = document.getElementById('form-success');

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    // In production: connect to FormSubmit, Netlify Forms, or email service
    form.hidden = true;
    if (success) success.hidden = false;
  });
</script>
