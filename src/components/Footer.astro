---
import { navigationLinks } from "@data/navigation";
const year = new Date().getFullYear();
---

<footer class="footer" role="contentinfo">
  <div class="footer-inner">
    <div class="footer-brand">
      <a href="/#inicio" class="logo" aria-label="JBV – Inicio">JBV</a>
      <p>
        Intermediación profesional de grúas autopropulsadas entre Alemania y
        España. 27 años de experiencia, transparencia total y los mejores
        precios.
      </p>
    </div>

    <nav class="footer-col" aria-label="Navegación secundaria">
      <h4>Navegación</h4>
      <ul>
        {
          navigationLinks.map((link) => (
            <li>
              <a href={link.href}>{link.label}</a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div class="footer-col">
      <h4>Contacto</h4>
      <!-- TODO: Reemplazar el número de teléfono, WhatsApp y email ficticio por los reales -->
      <ul>
        <li>
          <a href="tel:+34600000000">+34 600 000 000</a>
        </li>
        <li>
          <a
            href="https://wa.me/34600000000"
            target="_blank"
            rel="noopener noreferrer"
          >
            WhatsApp
          </a>
        </li>
        <li>
          <a href="mailto:info@jbv.com">info@jbv.com</a>
        </li>
      </ul>
    </div>
  </div>

  <div class="footer-bottom">
    <span>&copy; {year} JBV. Todos los derechos reservados.</span>
    <nav class="footer-legal" aria-label="Legal">
      <a href="/aviso-legal">Aviso Legal</a>
      <a href="/privacidad">Política de Privacidad</a>
      <a href="/cookies">Política de Cookies</a>
    </nav>
  </div>
</footer>

<style>
  .footer {
    background: oklch(0.09 0.02 252);
    border-block-start: 1px solid var(--border);
    padding-block: 4rem 2rem;
    padding-inline: 2rem;
  }

  .footer-inner {
    max-inline-size: var(--container);
    margin-inline: auto;
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: 3rem;
    margin-block-end: 3rem;
  }

  .footer-brand .logo {
    font-family: var(--font-display);
    font-size: 2.2rem;
    letter-spacing: 0.1em;
    color: var(--orange-500);
    text-shadow: var(--glow-sm);
    text-decoration: none;
    display: inline-block;
    margin-block-end: 1rem;
  }

  .footer-brand p {
    font-size: 0.88rem;
    color: var(--white-50);
    line-height: 1.65;
    max-inline-size: 300px;
  }

  .footer-col h4 {
    font-family: var(--font-condensed);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--white);
    margin-block-end: 1.25rem;
  }

  .footer-col ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }

  .footer-col a {
    font-size: 0.88rem;
    color: var(--white-50);
    text-decoration: none;
    transition: color var(--dur) var(--ease);
  }

  .footer-col a:hover {
    color: var(--orange-400);
  }

  .footer-bottom {
    max-inline-size: var(--container);
    margin-inline: auto;
    padding-block-start: 2rem;
    border-block-start: 1px solid var(--border);
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
    font-size: 0.8rem;
    color: var(--navy-500);
  }

  .footer-legal {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .footer-legal a {
    color: var(--navy-500);
    text-decoration: none;
    transition: color var(--dur) var(--ease);
  }

  .footer-legal a:hover {
    color: var(--orange-400);
  }

  @media (max-width: 768px) {
    .footer-inner {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .footer-bottom {
      flex-direction: column;
      text-align: center;
    }
  }
</style>
