---
import Icon from "./ui/Icon.astro";
---

<section id="inicio" class="hero" aria-label="Inicio">
  <!-- Background image -->
  <div class="hero-bg" aria-hidden="true">
    <img
      src="/images/bg-crane.png"
      alt=""
      fetchpriority="high"
      decoding="async"
      width="1920"
      height="1080"
    />
  </div>

  <!-- Gradient mask -->
  <div class="hero-mask" aria-hidden="true"></div>

  <!-- Content -->
  <div class="hero-content">
    <div class="hero-inner">
      <div class="hero-badge">
        <span>Alemania · España</span>
      </div>

      <h1 class="hero-title">
        <span class="accent">JBV</span>
        Intermediación<br />Profesional de<br />Grúas
      </h1>

      <p class="hero-subtitle">Autopropulsadas · Alemania–España</p>

      <p class="hero-desc">
        Para empresas que valoran la transparencia, la fiabilidad y el mejor
        precio en maquinaria de calidad alemana. Conectamos a su empresa
        directamente con las mejores oportunidades del mercado alemán.
      </p>

      <div class="hero-ctas">
        <a
          href="https://wa.me/34600000000"
          class="btn btn-primary"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Contactar por WhatsApp"
        >
          <Icon name="whatsapp" />
          WhatsApp
        </a>

        <a
          href="tel:+34600000000"
          class="btn btn-outline"
          aria-label="Llamar por teléfono"
        >
          <Icon name="phone" />
          Llamar ahora
        </a>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="hero-scroll" aria-hidden="true">
    <span>Scroll</span>
    <div class="scroll-line"></div>
  </div>
</section>
