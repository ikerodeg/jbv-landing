---
import { Image } from "astro:assets";
import Icon from "./ui/Icon.astro";
import bgCrane from "../assets/images/bg-crane.png";
---

<section id="inicio" class="hero" aria-label="Inicio">
  <!-- Background image -->
  <div class="hero-bg" aria-hidden="true">
    <Image src={bgCrane} alt="" fetchpriority="high" decoding="async" />
  </div>

  <!-- Gradient mask -->
  <div class="hero-mask" aria-hidden="true"></div>

  <!-- Content -->
  <div class="hero-content">
    <div class="hero-inner">
      <h1 class="hero-title">JBV</h1>
      <h2 class="hero-subtitle">
        Intermediación Profesional<br />de Grúas Autopropulsadas
      </h2>

      <div class="hero-badge">
        <span>Alemania · España</span>
      </div>

      <p class="hero-desc">
        Para empresas que valoran la transparencia, la fiabilidad y el mejor
        precio en maquinaria de calidad alemana. Conectamos a su empresa
        directamente con las mejores oportunidades del mercado alemán.
      </p>

      <div class="hero-ctas">
        <a
          href="https://wa.me/34600000000"
          class="btn btn-primary"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Contactar por WhatsApp"
        >
          <Icon name="whatsapp" />
          WhatsApp
        </a>

        <a
          href="tel:+34600000000"
          class="btn btn-outline"
          aria-label="Llamar por teléfono"
        >
          <Icon name="phone" />
          Llamar ahora
        </a>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="hero-scroll" aria-hidden="true">
    <span>Scroll</span>
    <div class="scroll-line"></div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-block-size: 100svh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-bg img {
    inline-size: 100%;
    block-size: 100%;
    object-fit: cover;
    object-position: 65% center;
  }

  .hero-mask {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      100deg,
      oklch(0.09 0.03 252 / 0.98) 0%,
      oklch(0.09 0.03 252 / 0.92) 25%,
      oklch(0.09 0.03 252 / 0.65) 45%,
      oklch(0.09 0.03 252 / 0.25) 65%,
      oklch(0.09 0.03 252 / 0.05) 80%,
      transparent 100%
    );
  }

  /* Bottom fade */
  .hero-mask::after {
    content: "";
    position: absolute;
    inset-block-end: 0;
    inset-inline: 0;
    block-size: 200px;
    background: linear-gradient(to top, var(--bg), transparent);
  }

  .hero-content {
    position: relative;
    z-index: 2;
    inline-size: 100%;
    max-inline-size: var(--container);
    margin-inline: auto;
    padding-inline: 2rem;
    /* padding-block: 10rem 6rem; */
  }

  .hero-inner {
    max-inline-size: 620px;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding-inline: 1.1rem;
    padding-block: 0.45rem;
    border: 1px solid oklch(0.73 0.19 52 / 0.35);
    border-radius: 100px;
    background: oklch(0.73 0.19 52 / 0.08);
    font-family: var(--font-condensed);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--orange-400);
    margin-block-end: 1rem;
    animation: fadeUp 0.7s 0.1s var(--ease) both;
  }

  .hero-badge::before {
    content: "";
    inline-size: 6px;
    block-size: 6px;
    border-radius: 50%;
    background: var(--orange-500);
    box-shadow: var(--glow-sm);
    animation: pulse 2s infinite;
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: 20rem;
    line-height: 0.9;
    color: var(--orange-500);
    text-shadow: var(--glow-md);
    letter-spacing: 0.02em;
    margin-block-end: 0.5rem;
    animation: fadeUp 0.7s 0.2s var(--ease) both;
  }

  .hero-subtitle {
    font-family: var(--font-condensed);
    font-size: 3rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    color: var(--white-80);
    margin-block: 1rem;
    animation: fadeUp 0.7s 0.3s var(--ease) both;
  }

  .hero-desc {
    font-size: clamp(0.9rem, 1.5vw, 1rem);
    color: var(--white-50);
    line-height: 1.7;
    max-inline-size: 520px;
    margin-block-end: 2.5rem;
    animation: fadeUp 0.7s 0.4s var(--ease) both;
  }

  .hero-ctas {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    animation: fadeUp 0.7s 0.5s var(--ease) both;
  }

  .hero-scroll {
    position: absolute;
    inset-block-end: 2.5rem;
    inset-inline-start: 50%;
    transform: translateX(-50%);
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    color: var(--white-50);
    font-family: var(--font-condensed);
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    animation: fadeIn 1s 1.2s both;
  }

  .scroll-line {
    inline-size: 1px;
    block-size: 50px;
    background: linear-gradient(to bottom, var(--orange-500), transparent);
    animation: scrollLine 1.5s ease-in-out infinite;
  }
</style>
