---
import { steps } from "@data/steps";
---

<section id="proceso" class="section process" aria-label="Proceso de compra">
  <div class="section-inner">
    <div class="process-inner">
      <div class="process-header reveal">
        <p class="section-eyebrow">Proceso de Compra</p>
        <h2 class="section-title">
          Cinco pasos hacia<br />su <span class="accent">grúa ideal</span>
        </h2>
        <p class="section-lead">
          Un proceso sencillo, transparente y diseñado para que usted solo tome
          la decisión final. Nosotros nos encargamos de todo lo demás.
        </p>
        <a href="#contacto" class="btn btn-primary">Iniciar consulta</a>
      </div>

      <div class="process-track" role="list">
        {
          steps.map((step, i) => (
            <div
              class={`process-step reveal reveal-delay-${i + 1}`}
              role="listitem"
            >
              <div class="step-aside" aria-hidden="true">
                <div class="step-num">{step.num}</div>
                <div class="step-line" />
              </div>
              <div class="step-body">
                <h3>{step.title}</h3>
                <p>{step.desc}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .process {
    background: var(--navy-800);
  }

  .process-track {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .process-step {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 2rem;
    align-items: stretch;
    padding-block-end: 3rem;
  }

  .process-step:last-child {
    padding-block-end: 0;
  }

  .step-aside {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
  }

  .step-num {
    inline-size: 56px;
    block-size: 56px;
    border-radius: 50%;
    border: 2px solid oklch(0.73 0.19 52 / 0.4);
    background: oklch(0.73 0.19 52 / 0.08);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-size: 1.4rem;
    color: var(--orange-500);
    text-shadow: var(--glow-sm);
    flex-shrink: 0;
    transition: all var(--dur) var(--ease);
  }

  .process-step:hover .step-num {
    border-color: var(--orange-500);
    box-shadow: var(--glow-sm);
    background: oklch(0.73 0.19 52 / 0.15);
  }

  .step-line {
    flex: 1;
    inline-size: 1px;
    background: linear-gradient(
      to bottom,
      oklch(0.73 0.19 52 / 0.3),
      oklch(0.73 0.19 52 / 0.05)
    );
    margin-block-start: 0.5rem;
  }

  .process-step:last-child .step-line {
    display: none;
  }

  .step-body {
    padding-block: 0.75rem 0;
  }

  .step-body h3 {
    font-family: var(--font-condensed);
    font-size: 1.15rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--white);
    margin-block-end: 0.5rem;
  }

  .step-body p {
    font-size: 0.92rem;
    color: var(--white-50);
    line-height: 1.65;
  }

  @media (min-width: 900px) {
    .process-inner {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 5rem;
      align-items: start;
    }

    .process-header {
      position: sticky;
      inset-block-start: 120px;
    }
  }
</style>
