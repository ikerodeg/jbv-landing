---
import { services } from "@data/services";
---

<section id="servicios" class="section services" aria-label="Lo que hacemos">
  <div class="section-inner">
    <p class="section-eyebrow reveal">Lo Que Hacemos</p>
    <h2 class="section-title reveal">
      Intermediación <span class="accent">profesional</span> de grúas
    </h2>
    <p class="section-lead reveal">
      Facilitamos la compra de grúas autopropulsadas de origen alemán para
      empresas españolas. Un servicio integral basado en la confianza, la
      experiencia y el trato directo.
    </p>

    <div class="services-grid">
      {
        services.map((s, i) => (
          <article class={`service-card reveal reveal-delay-${(i % 3) + 1}`}>
            <div class="service-icon" aria-hidden="true">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
                aria-hidden="true"
              >
                <Fragment set:html={s.icon} />
              </svg>
            </div>
            <h3>{s.title}</h3>
            <p>{s.desc}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .services {
    background: var(--navy-900);
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.25rem;
  }

  .service-card {
    padding-block: 2rem;
    padding-inline: 1.75rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--r-lg);
    transition: all var(--dur) var(--ease);
    position: relative;
    overflow: hidden;
  }

  .service-card::before {
    content: "";
    position: absolute;
    inset-block-start: 0;
    inset-inline: 0;
    block-size: 2px;
    background: linear-gradient(
      90deg,
      transparent,
      var(--orange-500),
      transparent
    );
    opacity: 0;
    transition: opacity var(--dur) var(--ease);
  }

  .service-card:hover {
    border-color: oklch(0.73 0.19 52 / 0.25);
    transform: translateY(-5px);
    box-shadow: 0 20px 50px oklch(0 0 0 / 0.3);
  }

  .service-card:hover::before {
    opacity: 1;
  }

  .service-icon {
    inline-size: 50px;
    block-size: 50px;
    border-radius: var(--r-md);
    background: oklch(0.73 0.19 52 / 0.1);
    border: 1px solid oklch(0.73 0.19 52 / 0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-block-end: 1.25rem;
    color: var(--orange-500);
    transition: box-shadow var(--dur) var(--ease);
  }

  .service-card:hover .service-icon {
    box-shadow: var(--glow-sm);
  }

  .service-icon svg {
    inline-size: 24px;
    block-size: 24px;
  }

  .service-card h3 {
    font-family: var(--font-condensed);
    font-size: 1.15rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    color: var(--white);
    margin-block-end: 0.75rem;
    text-transform: uppercase;
  }

  .service-card p {
    font-size: 0.92rem;
    color: var(--white-50);
    line-height: 1.65;
  }
</style>
