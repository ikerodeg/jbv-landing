---
import { services } from '@data/services';
---

<section id="servicios" class="section services" aria-label="Lo que hacemos">
  <div class="section-inner">
    <p class="section-eyebrow reveal">Lo Que Hacemos</p>
    <h2 class="section-title reveal">
      Intermediación <span class="accent">profesional</span> de grúas
    </h2>
    <p class="section-lead reveal">
      Facilitamos la compra de grúas autopropulsadas de origen alemán para empresas españolas.
      Un servicio integral basado en la confianza, la experiencia y el trato directo.
    </p>

    <div class="services-grid">
      {services.map((s, i) => (
        <article class={`service-card reveal reveal-delay-${(i % 3) + 1}`}>
          <div class="service-icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <Fragment set:html={s.icon} />
            </svg>
          </div>
          <h3>{s.title}</h3>
          <p>{s.desc}</p>
        </article>
      ))}
    </div>
  </div>
</section>
