---
import { reasons } from '@data/reasons';
---

<section id="por-que" class="section why-us" aria-label="Por qué elegirnos">
  <div class="section-inner">
    <p class="section-eyebrow reveal">Por Qué Elegirnos</p>
    <h2 class="section-title reveal">
      Su <span class="accent">socio de confianza</span><br>en grúas alemanas
    </h2>
    <p class="section-lead reveal">
      No somos un intermediario más. Somos su extensión en Alemania, con la experiencia
      y los contactos para conseguirle la mejor maquinaria al mejor precio.
    </p>

    <div class="why-grid">
      {reasons.map((r, i) => (
        <article class={`why-card reveal reveal-delay-${(i % 3) + 1}`}>
          <div class="why-icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
              <Fragment set:html={r.icon} />
            </svg>
          </div>
          <div>
            <h3>{r.title}</h3>
            <p>{r.desc}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
