---
import { navigationLinks } from "@data/navigation";
import { contact } from "@data/contact";
const year = new Date().getFullYear();
---

<footer class="footer" role="contentinfo">
  <div class="footer-inner">
    <div class="footer-brand">
      <a
        href={`${import.meta.env.BASE_URL}#inicio`}
        class="logo"
        aria-label="JBV – Inicio">JBV</a
      >
      <p>
        Intermediación profesional de grúas autopropulsadas entre Alemania y
        España. 27 años de experiencia, transparencia total y los mejores
        precios.
      </p>
    </div>

    <nav class="footer-col" aria-label="Navegación secundaria">
      <h4>Navegación</h4>
      <ul>
        {
          navigationLinks.map((link) => (
            <li>
              <a href={link.href}>{link.label}</a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div class="footer-col">
      <h4>Contacto</h4>
      <ul>
        <li>
          <a href={contact.phoneTel}>{contact.phoneDisplay}</a>
        </li>
        <li>
          <a
            href={contact.whatsapp}
            target="_blank"
            rel="noopener noreferrer"
          >
            WhatsApp
          </a>
        </li>
        <li>
          <a href={contact.emailHref}>{contact.email}</a>
        </li>
      </ul>
    </div>
  </div>

  <div class="footer-bottom">
    <span>&copy; {year} JBV. Todos los derechos reservados.</span>
    <nav class="footer-legal" aria-label="Legal">
      <a href={`${import.meta.env.BASE_URL}aviso-legal/`}>Aviso Legal</a>
      <a href={`${import.meta.env.BASE_URL}privacidad/`}
        >Política de Privacidad</a
      >
      <a href={`${import.meta.env.BASE_URL}cookies/`}>Política de Cookies</a>
    </nav>
  </div>
</footer>

<style>
  /* ═══════════════════════════════════════════
                  Mobile-first
  ═══════════════════════════════════════════ */
  .footer {
    position: relative;
  }

  .footer::before {
    content: "";
    position: absolute;
    inset-block-start: 0;
    inset-inline: 0;
    block-size: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      var(--orange-500),
      transparent
    );
    opacity: 0.3;
  }
  .footer-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    justify-items: center;
    padding-block: var(--margin-space-3);
  }

  .footer-brand {
    grid-column: 1 / span 2;
  }

  .footer-brand .logo {
    font-family: var(--font-display);
    font-size: 2.2rem;
    letter-spacing: 0.1em;
    color: var(--orange-500);
    text-shadow: var(--glow-sm);
    text-decoration: none;
    display: inline-block;
    margin-block-end: var(--space-5);
  }

  .footer-brand p {
    font-size: 0.88rem;
    color: var(--white-50);
    line-height: 1.65;
    max-inline-size: 300px;
  }

  .footer-col h4 {
    font-family: var(--font-condensed);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--white);
    margin-block-end: var(--space-6);
  }

  .footer-col ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }

  .footer-col a {
    font-size: 0.88rem;
    color: var(--white-50);
    text-decoration: none;
    transition: color var(--dur) var(--ease);
  }

  .footer-col a:hover {
    color: var(--orange-400);
  }

  .footer-bottom {
    margin-inline: auto;
    padding-block: var(--margin-space-2);
    border-block-start: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
    font-size: 0.8rem;
    color: var(--navy-500);
  }

  .footer-legal {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .footer-legal a {
    color: var(--navy-500);
    text-decoration: none;
    transition: color var(--dur) var(--ease);
  }

  .footer-legal a:hover {
    color: var(--orange-400);
  }

  /* ═══════════════════════════════════════════
                    Tablet
  ═══════════════════════════════════════════ */

  @media (width >= 640px) {
    .footer-inner {
      display: flex;
      flex-direction: row;
      justify-content: space-around;
    }

    .footer-brand .logo {
      font-size: 5rem;
    }

    .footer-brand p {
      font-size: 1.2rem;
      text-wrap: balance;
    }

    .footer-col h4 {
      font-size: 1.2rem;
    }

    .footer-col a {
      font-size: 1.2rem;
    }
  }
  /* ═══════════════════════════════════════════
                      Desktop
  ═══════════════════════════════════════════ */

  @media (width >= 920px) {
    .footer-bottom,
    .footer-legal a {
      font-size: var(--fs-txt-mob-fld-2);
      color: oklch(var(--white-base) / 0.3);
    }
  }
</style>
