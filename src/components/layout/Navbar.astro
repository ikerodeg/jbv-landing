---
import { navigationLinks } from "@data/navigation";
const links = navigationLinks;
---

<header>
  <nav
    class="navbar"
    id="navbar"
    role="navigation"
    aria-label="Navegación principal"
  >
    <a
      href={`${import.meta.env.BASE_URL}#inicio`}
      class="navbar-logo"
      aria-label="JBV Grúas – Inicio"
    >
      <span class="logo-hook" aria-hidden="true">🪝</span>
      <span class="logo-text">
        <span class="logo-title"><span class="logo-jbv">JBV</span> <span class="logo-gruas">GRÚAS</span></span>
        <span class="logo-subtitle">INTERMEDIACIÓN PROFESIONAL</span>
      </span>
    </a>

    <button
      class="nav-toggle"
      id="nav-toggle"
      aria-controls="nav-menu"
      aria-expanded="false"
      aria-label="Abrir menú de navegación"
    >
      <span></span>
      <span></span>
      <span></span>
    </button>

    <ul class="nav-links" id="nav-menu" role="menubar">
      {
        links.map((link) => (
          <li role="none">
            <a
              href={link.href}
              role="menuitem"
              class="nav-link"
              data-section={link.href.replace(/^\/?#/, "")}
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</header>

<div class="nav-overlay" id="nav-overlay" aria-hidden="true"></div>

<script>
  const navbar = document.getElementById("navbar");
  const toggle = document.getElementById("nav-toggle");
  const menu = document.getElementById("nav-menu");
  const overlay = document.getElementById("nav-overlay");
  const navLinks = document.querySelectorAll<HTMLAnchorElement>(".nav-link");

  // Scroll opacity
  let isTicking = false;

  const onScroll = () => {
    if (!isTicking) {
      window.requestAnimationFrame(() => {
        navbar?.classList.toggle("scrolled", window.scrollY > 60);

        // Active section highlight
        const sections = [...navLinks].map((a) => ({
          a,
          el: document.getElementById(a.dataset.section ?? ""),
        }));

        let current = "";
        for (const { el, a } of sections) {
          if (el && el.getBoundingClientRect().top <= 140) {
            current = a.dataset.section ?? "";
          }
        }
        for (const { a } of sections) {
          a.classList.toggle("active", a.dataset.section === current);
        }

        isTicking = false;
      });
      isTicking = true;
    }
  };

  window.addEventListener("scroll", onScroll, { passive: true });
  onScroll();

  // Shared close helper
  const closeMenu = () => {
    toggle?.setAttribute("aria-expanded", "false");
    menu?.classList.remove("open");
    overlay?.classList.remove("open");
    overlay?.setAttribute("aria-hidden", "true");
  };

  // Mobile toggle
  toggle?.addEventListener("click", () => {
    const open = toggle.getAttribute("aria-expanded") === "true";
    const next = !open;
    toggle.setAttribute("aria-expanded", String(next));
    menu?.classList.toggle("open", next);
    overlay?.classList.toggle("open", next);
    overlay?.setAttribute("aria-hidden", String(!next));
  });

  // Close on link click
  navLinks.forEach((a) => {
    a.addEventListener("click", closeMenu);
  });

  // Close on overlay click
  overlay?.addEventListener("click", closeMenu);

  // Close on Escape key
  document.addEventListener("keydown", (e) => {
    if (
      e.key === "Escape" &&
      toggle?.getAttribute("aria-expanded") === "true"
    ) {
      closeMenu();
      toggle?.focus();
    }
  });
</script>

<style>
  .navbar {
    position: fixed;
    inset-block-start: 0;
    inset-inline: 0;
    z-index: 100;
    padding-block: 0.3rem;
    padding-inline: clamp(1.5rem, 4vw, 3rem);
    display: flex;
    align-items: center;
    justify-content: space-between;
    background-color: oklch(var(--navy-900-base) / 0);
    backdrop-filter: blur(0px);
    transition:
      background-color 0.5s var(--ease),
      backdrop-filter 0.5s var(--ease),
      box-shadow 0.5s var(--ease),
      padding 0.4s var(--ease);
  }

  .navbar.scrolled {
    background-color: oklch(0.1 0.025 252 / 0.92);
    backdrop-filter: blur(20px) saturate(150%);
    box-shadow:
      0 1px 0 var(--white-08),
      0 8px 32px oklch(0 0 0 / 0.4);
  }

  .navbar-logo {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
    opacity: 0;
    translate: 0 -0.5rem;
    pointer-events: none;
    transition:
      opacity 0.4s var(--ease),
      translate 0.4s var(--ease);
  }

  .navbar.scrolled .navbar-logo {
    opacity: 1;
    translate: 0 0;
    pointer-events: auto;
  }

  .logo-hook {
    font-size: 1.6rem;
    line-height: 1;
    flex-shrink: 0;
  }

  .logo-text {
    display: flex;
    flex-direction: column;
    line-height: 1.15;
  }

  .logo-title {
    font-family: var(--font-body), sans-serif;
    font-size: 1.15rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .logo-jbv {
    color: var(--white);
  }

  .logo-gruas {
    color: var(--orange-500);
  }

  .logo-subtitle {
    font-family: var(--font-condensed), sans-serif;
    font-size: 0.55rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    color: var(--white-80);
    text-transform: uppercase;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 2.5rem;
    list-style: none;
  }

  .nav-links a {
    font-family: var(--font-condensed);
    font-size: 0.95rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--white-80);
    text-decoration: none;
    position: relative;
    padding-block-end: 4px;
    transition: color var(--dur) var(--ease);
  }

  .nav-links a::after {
    content: "";
    position: absolute;
    inset-block-end: 0;
    inset-inline-start: 0;
    inline-size: 0;
    block-size: 2px;
    background: var(--orange-500);
    box-shadow: var(--glow-sm);
    transition: inline-size 0.4s var(--ease);
  }

  .nav-links a:hover,
  .nav-links a.active {
    color: var(--orange-400);
    text-shadow: var(--glow-sm);
  }

  .nav-links a:hover::after,
  .nav-links a.active::after {
    inline-size: 100%;
    box-shadow: var(--glow-md);
  }

  /* Hamburger */
  .nav-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 6px;
    z-index: 200;
  }

  .nav-toggle span {
    display: block;
    inline-size: 26px;
    block-size: 2px;
    background: var(--white);
    border-radius: 2px;
    transition:
      transform 0.3s var(--ease),
      opacity 0.3s;
  }

  .nav-toggle[aria-expanded="true"] span:nth-child(1) {
    transform: rotate(45deg) translate(5px, 5px);
  }

  .nav-toggle[aria-expanded="true"] span:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }

  .nav-toggle[aria-expanded="true"] span:nth-child(3) {
    transform: rotate(-45deg) translate(5px, -5px);
  }

  @media (max-width: 920px) {
    .nav-toggle {
      display: flex;
    }

    .nav-links {
      position: fixed;
      inset-block: 0;
      inset-inline-end: 0;
      inline-size: min(320px, 85vw);
      block-size: 100dvh;
      flex-direction: column;
      justify-content: center;
      gap: 2rem;
      background: oklch(0.1 0.025 252 / 0.97);
      backdrop-filter: blur(24px);
      transform: translateX(110%);
      transition: transform 0.4s var(--ease);
      padding-inline: var(--space-9);
      border-inline-start: 1px solid var(--border);
    }

    .nav-links.open {
      transform: translateX(0);
    }

    .nav-links a {
      font-size: 1.2rem;
    }
  }

  /* Overlay mobile */
  .nav-overlay {
    position: fixed;
    inset: 0;
    z-index: 50;
    background: oklch(0 0 0 / 0.55);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.4s var(--ease);
    backdrop-filter: blur(2px);
  }

  .nav-overlay.open {
    opacity: 1;
    pointer-events: auto;
  }
  */
</style>
