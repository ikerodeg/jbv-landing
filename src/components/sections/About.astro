---
import { getImage } from "astro:assets";
import ximoAboutMobile from "../../assets/images/ximo-mobile.webp";
import ximoAboutTablet from "../../assets/images/ximo-tablet.webp";
import ximoAboutDesktop from "../../assets/images/ximo-desktop.webp";

const mobile = await getImage({ src: ximoAboutMobile });
const tablet = await getImage({ src: ximoAboutTablet });
const desktop = await getImage({ src: ximoAboutDesktop });
---

<section id="sobre-mi" class="section about" aria-label="Sobre Mí">
  <div class="section-eyebrow about-eyebrow reveal reveal-delay-1">
    Sobre Mí
  </div>
  <h2 class="section-title about-title">
    Hola, soy <span class="accent">Ximo</span>
  </h2>
  <div class="section-inner about-inner">
    <div class="about-photo reveal reveal-delay-2">
      <picture class="about-photo-frame reveal">
        <source media="(min-width: 920px)" srcset={desktop.src} />
        <source media="(min-width: 640px)" srcset={tablet.src} />
        <img
          src={mobile.src}
          alt="Ximo, fundador de JBV"
          class="img-main"
          fetchpriority="high"
        />
        <!-- Neon border overlay -->
        <div class="about-glow" aria-hidden="true"></div>
      </picture>
      <div class="stats-row">
        <div class="stat reveal reveal-delay-1">
          <div class="stat-num">14</div>
          <div class="stat-label">Años viviendo en Alemania</div>
        </div>
        <div class="stat reveal reveal-delay-2">
          <div class="stat-num">27</div>
          <div class="stat-label">Años de experiencia en el sector</div>
        </div>
        <div class="stat reveal reveal-delay-3">
          <div class="stat-num">100%</div>
          <div class="stat-label">Transparencia en cada operación</div>
        </div>
      </div>
    </div>
    <div class="about-text reveal">
      <!-- Tarjeta 1: Conocimiento del mercado -->
      <article class="card sides about-card reveal reveal-delay-1">
        <header class="card-header">
          <div class="card-icon" aria-hidden="true">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <circle cx="12" cy="12" r="10"></circle>
              <path d="M12 16v-4M12 8h.01"></path>
            </svg>
          </div>
          <h3 class="card-title">Conocimiento de primera mano</h3>
        </header>
        <p class="card-text">
          Conozco el mercado alemán en profundidad: cada fabricante, cada
          detalle técnico, cada oportunidad que otros no ven.
        </p>
      </article>

      <!-- Tarjeta 2: Experiencia directa -->
      <article class="card sides about-card reveal reveal-delay-2">
        <header class="card-header">
          <div class="card-icon" aria-hidden="true">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M12 2L2 7l10 5 10-5-10-5z"></path>
              <path d="M2 17l10 5 10-5"></path>
              <path d="M2 12l10 5 10-5"></path>
            </svg>
          </div>
          <h3 class="card-title">Gran experiencia</h3>
        </header>
        <p class="card-text">
          Esa trayectoria directa me permite encontrar exactamente lo que su
          empresa necesita, al mejor precio y con total garantía.
        </p>
      </article>

      <!-- Tarjeta 3: La empresa -->
      <article class="card sides about-card reveal reveal-delay-3">
        <header class="card-header">
          <div class="card-icon" aria-hidden="true">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <rect x="2" y="7" width="20" height="14" rx="2"></rect>
              <path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"></path>
              <line x1="12" y1="12" x2="12" y2="12"></line>
              <path d="M2 12h20"></path>
            </svg>
          </div>
          <h3 class="card-title">Empresa con propósito</h3>
        </header>
        <p class="card-text">
          Nacimos para ofrecer maquinaria alemana con transparencia total y
          profesionalidad durante todo el proceso de compra.
        </p>
      </article>
    </div>
  </div>
</section>

<style>
  /* ═══════════════════════════════════════════
                    Mobile-first
    ═══════════════════════════════════════════ */

  /* Seccion About */
  .about-text {
    display: flex;
    flex-direction: column;
    gap: var(--padV-mob-3);
  }

  .about-photo {
    display: flex;
    align-items: center;
    margin-block-end: var(--padV-mob-3);
  }

  .about-glow {
    position: absolute;
    inset-block-start: 0;
    inline-size: 100%;
    block-size: 100%;
    background: radial-gradient(
      ellipse 80% 70% at center,
      oklch(var(--orng-base)) 0%,
      transparent 70%
    );
  }

  .about-photo-frame {
    inline-size: 100%;
    block-size: 100%;
  }

  .img-main {
    margin-inline: auto;
    block-size: 100%;
    max-inline-size: 100%;
    position: relative;
    z-index: 1;
    mask-image: linear-gradient(
      to bottom,
      oklch(var(--black-base)) 90%,
      transparent 100%
    );
  }

  /* Contenedor de estadisticas */
  .stats-row {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-around;
    gap: var(--padV-mob-1);
  }

  /* tarjeta de estadistica */
  .stat {
    text-align: center;
    inline-size: clamp(100px, 25vw, 200px);
    padding-block: var(--padV-mob-0);
    padding-inline: var(--padH-mob-2);
    border: 1px solid oklch(var(--orng-base) / 0.15);
    border-radius: var(--r-md);
    background: oklch(var(--orng-base) / 0.04);
    position: relative;
    overflow: hidden;
    font-size: 0.8rem;
    transition:
      border-color var(--dur) var(--ease),
      box-shadow var(--dur) var(--ease);
  }

  /* Decorativo de la tarjeta de estadistica */
  .stat::before {
    content: "";
    position: absolute;
    inset-block-start: 0;
    inset-inline: 0;
    block-size: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      oklch(var(--orng-base)),
      transparent
    );
    opacity: 1;
    transition: opacity var(--dur) var(--ease);
  }

  /* Decorativo de la tarjeta de estadistica */
  .stat::after {
    content: "";
    position: absolute;
    inset-block-end: 0;
    inset-inline: 0;
    block-size: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      oklch(var(--orng-base)),
      transparent
    );
    opacity: 1;
    transition: opacity var(--dur) var(--ease);
  }

  /* Hover de la tarjeta de estadistica */
  .stat:hover {
    border-color: oklch(var(--orng-base) / 0.4);
    box-shadow: 0 8px 30px oklch(var(--orng-base) / 0.1);
  }

  /* Hover de la tarjeta de estadistica */
  .stat:hover::before {
    opacity: 1;
  }

  /* Hover de la tarjeta de estadistica */
  .stat:hover::after {
    opacity: 1;
  }

  /* Numero de la tarjeta de estadistica */
  .stat-num {
    font-size: var(--fntSz-txt-mob-7);
    color: oklch(var(--orng-base));
    text-shadow: var(--glow-sm);
    line-height: 1;
    margin-block-end: var(--marV-mob-0);
    letter-spacing: 0.02em;
  }

  /* Etiqueta de la tarjeta de estadistica */
  .stat-label {
    font-size: var(--fntSz-txt-mob-0);
    font-weight: var(--fntWght-semibold);
    color: oklch(var(--white-base) / 0.6);
    line-height: 1.3;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  /* ═══════════════════════════════════════════
                    Tablet
  ═══════════════════════════════════════════ */

  @media (width >= 640px) {
    .about {
      padding-block-start: var(--padV-mob-7);
    }

    .about-title {
      margin-block-end: var(--marV-mob-4);
    }

    .img-main {
      inline-size: auto;
      block-size: auto;
      max-block-size: 40svh;
    }

    .about-glow {
      background: radial-gradient(
        ellipse 80% 70% at center,
        oklch(var(--orng-base)) 0%,
        transparent 60%
      );
    }

    .stats-row {
      background-color: transparent;
      gap: var(--padV-mob-2);
      align-self: stretch;
    }

    .about-text {
      flex-direction: column;
      gap: var(--padV-mob-2);
      justify-content: space-between;
      flex-wrap: wrap;
    }

    .about-card:last-child {
      inline-size: 100%;
    }
  }

  /* ═══════════════════════════════════════════
                    Desktop
  ═══════════════════════════════════════════ */

  @media (width >= 920px) {
    /* Contenido principal */
    .about-inner {
      margin-inline: auto;
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      justify-content: center;
      justify-items: stretch;
      grid-column-gap: var(--padH-dtp-5);
    }

    .about-photo {
      block-size: 100%;
      margin: 0;
      padding: 0;
      gap: var(--padV-mob-2);
    }

    .img-main {
      block-size: 100%;
      max-inline-size: 100%;
      max-block-size: 100%;
    }

    .stats-row {
      block-size: 100%;
      flex-direction: column;
      justify-content: space-between;
      align-items: center;
    }

    .stat {
      block-size: 145px;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: var(--padV-mob-1);
    }

    .stat-num {
      font-size: var(--fntSz-ttl-dtp-4);
    }

    .stat-label {
      font-size: var(--fntSz-txt-dtp-4);
    }

    .about-text {
      display: flex;
      flex-direction: column;
      flex-wrap: nowrap;
      max-inline-size: 750px;
      align-items: center;
      justify-content: space-between;
      padding: 0;
      margin: 0;
      gap: var(--padV-mob-6);
    }

    .about-card {
      display: flex;
      flex-direction: column;
      align-items: start;
      gap: var(--padV-mob-1);
      padding-inline-start: var(--padH-dtp-4);
      block-size: 145px;
    }

    .card-title {
      font-size: var(--fntSz-txt-dtp-3);
    }

    .card-text {
      font-size: var(--fntSz-txt-dtp-4);
      text-wrap: balance;
    }

    .card-icon {
      inline-size: 44px;
      block-size: 44px;
    }

    .card-icon svg {
      inline-size: 36px;
      block-size: 36px;
    }
  }
</style>
