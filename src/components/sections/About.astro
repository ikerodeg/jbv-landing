---
import { Image } from "astro:assets";
import { getImage } from "astro:assets";
import ximoAbout from "../../assets/images/ximo.webp";
import ximoAboutMobile from "../../assets/images/ximo-mobile.webp";
import ximoAboutTablet from "../../assets/images/ximo-tablet.webp";
import ximoAboutDesktop from "../../assets/images/ximo-desktop.webp";

const mobile = await getImage({ src: ximoAboutMobile });
const tablet = await getImage({ src: ximoAboutTablet });
const desktop = await getImage({ src: ximoAboutDesktop });
---

<section id="sobre-mi" class="section about" aria-label="Sobre Mí">
  <div class="section-eyebrow about-eyebrow reveal reveal-delay-1">
    Sobre Mí
  </div>
  <h2 class="section-title about-title">
    Hola, soy <span class="accent">Ximo</span>
  </h2>
  <div class="section-inner about-inner">
    <div class="about-photo reveal reveal-delay-2">
      <picture class="about-photo-frame reveal">
        <source media="(min-width: 920px)" srcset={desktop.src} />
        <source media="(min-width: 640px)" srcset={tablet.src} />
        <img
          src={mobile.src}
          alt="Ximo, fundador de JBV"
          class="img-main"
          fetchpriority="high"
          decoding="async"
        />
        <!-- Neon border overlay -->
        <div class="about-glow" aria-hidden="true"></div>
      </picture>
      <div class="stats-row">
        <div class="stat reveal reveal-delay-1">
          <div class="stat-num">27</div>
          <div class="stat-label">Años de experiencia en el sector</div>
        </div>
        <div class="stat reveal reveal-delay-2">
          <div class="stat-num">14</div>
          <div class="stat-label">Años viviendo en Alemania</div>
        </div>
        <div class="stat reveal reveal-delay-3">
          <div class="stat-num">100%</div>
          <div class="stat-label">Transparencia en cada operación</div>
        </div>
      </div>
    </div>
    <div class="about-text reveal">
      <!-- Tarjeta 1: Conocimiento del mercado -->
      <article class="about-card reveal reveal-delay-1">
        <div class="about-card-icon" aria-hidden="true">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <circle cx="12" cy="12" r="10"></circle>
            <path d="M12 16v-4M12 8h.01"></path>
          </svg>
        </div>
        <div class="about-card-body">
          <h3 class="about-card-title">Conocimiento de primera mano</h3>
          <p class="about-card-text">
            Conozco el mercado alemán en profundidad: cada fabricante, cada
            detalle técnico, cada oportunidad que otros no ven.
          </p>
        </div>
      </article>

      <!-- Tarjeta 2: Experiencia directa -->
      <article class="about-card reveal reveal-delay-2">
        <div class="about-card-icon" aria-hidden="true">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M12 2L2 7l10 5 10-5-10-5z"></path>
            <path d="M2 17l10 5 10-5"></path>
            <path d="M2 12l10 5 10-5"></path>
          </svg>
        </div>
        <div class="about-card-body">
          <h3 class="about-card-title">27 años de experiencia</h3>
          <p class="about-card-text">
            Esa trayectoria directa me permite encontrar exactamente lo que su
            empresa necesita, al mejor precio y con total garantía.
          </p>
        </div>
      </article>

      <!-- Tarjeta 3: La empresa -->
      <article class="about-card reveal reveal-delay-3">
        <div class="about-card-icon" aria-hidden="true">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <rect x="2" y="7" width="20" height="14" rx="2"></rect>
            <path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"></path>
            <line x1="12" y1="12" x2="12" y2="12"></line>
            <path d="M2 12h20"></path>
          </svg>
        </div>
        <div class="about-card-body">
          <h3 class="about-card-title">Empresa con propósito</h3>
          <p class="about-card-text">
            Nacimos para ofrecer maquinaria alemana con transparencia total y
            profesionalidad durante todo el proceso de compra.
          </p>
        </div>
      </article>
    </div>
  </div>
</section>

<style>
  /* ═══════════════════════════════════════════
                    Mobile-first
    ═══════════════════════════════════════════ */

  /* Seccion About */
  .about {
    background: oklch(var(--navy-900-base));
  }

  .about-text {
    display: flex;
    flex-direction: column;
    gap: clamp(1rem, -2.41rem + 14.55vw, 1.5rem); /* <--- */
  }

  .about-card {
    display: flex;
    align-items: flex-start;
    gap: var(--pad-mob-fld-2);
    padding-block: var(--pad-mob-fld-2);
    padding-inline: var(--pad-mob-fld-3);
    background: oklch(var(--navy-800-base));
    border: 1px solid oklch(var(--orng-base) / 0.12);
    border-radius: var(--r-lg);
    position: relative;
    overflow: hidden;
    transition:
      border-color var(--dur) var(--ease),
      box-shadow var(--dur) var(--ease);
  }

  .about-card::before {
    content: "";
    position: absolute;
    inset-block: 0;
    inset-inline-start: 0;
    inline-size: 2px;
    background: linear-gradient(
      to bottom,
      transparent,
      oklch(var(--orng-base)),
      transparent
    );
    opacity: 0.6;
    transition: opacity var(--dur) var(--ease);
  }

  .about-card:hover {
    border-color: oklch(var(--orng-base) / 0.3);
    box-shadow: 0 4px 20px oklch(var(--orng-base) / 0.07);
  }

  .about-card:hover::before {
    opacity: 1;
  }

  /* Icono — mobile */
  .about-card-icon {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    inline-size: 2.25rem;
    block-size: 2.25rem;
    border-radius: var(--r-md);
    background: oklch(var(--orng-base) / 0.08);
    border: 1px solid oklch(var(--orng-base) / 0.2);
    color: oklch(var(--orng-base));
  }

  .about-card-icon svg {
    inline-size: 1.1rem;
    block-size: 1.1rem;
    filter: drop-shadow(0 0 3px oklch(var(--orng-base) / 0.5));
  }

  /* Cuerpo — mobile */
  .about-card-body {
    display: flex;
    flex-direction: column;
    gap: var(--gap-mob-fld-1);
  }

  /* Título — mobile */
  .about-card-title {
    font-family: var(--font-condensed);
    font-size: var(--fs-txt-mob-fld-3);
    font-weight: var(--fntWght-semibold);
    color: oklch(var(--white-base));
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin-block-end: 0;
    line-height: 1.2;
  }

  /* Texto — mobile */
  .about-card-text {
    font-size: var(--fs-txt-mob-fld-2);
    color: oklch(var(--white-base) / 0.65);
    line-height: 1.65;
    text-wrap: pretty;
    margin-block-end: 0;
  }

  .about-photo {
    display: flex;
    align-items: center;
    margin-block-end: clamp(1rem, -12.64rem + 58.18vw, 3rem); /* <--- */
  }

  .about-photo-frame {
    inline-size: 100%;
    block-size: 100%;
  }

  .img-main {
    margin-inline: auto;
    block-size: 100%;
    max-inline-size: 100%;
    position: relative;
    z-index: 1;
    mask-image: linear-gradient(
      to bottom,
      oklch(var(--black-base)) 90%,
      transparent 100%
    );
  }

  /* Contenedor de estadisticas */
  .stats-row {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-around;
    gap: clamp(0.5rem, -6.32rem + 29.09vw, 1.5rem); /* <--- */
  }

  /* tarjeta de estadistica */
  .stat {
    text-align: center;
    inline-size: clamp(100px, 25vw, 200px);
    padding-block: var(--pad-mob-fld-1);
    padding-inline: var(--pad-mob-fld-1);
    border: 1px solid oklch(var(--orng-base) / 0.15);
    border-radius: var(--r-md);
    background: oklch(var(--orng-base) / 0.04);
    position: relative;
    overflow: hidden;
    font-size: 0.8rem;
    transition:
      border-color var(--dur) var(--ease),
      box-shadow var(--dur) var(--ease);
  }

  /* Decorativo de la tarjeta de estadistica */
  .stat::before {
    content: "";
    position: absolute;
    inset-block-start: 0;
    inset-inline: 0;
    block-size: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      oklch(var(--orng-base)),
      transparent
    );
    opacity: 1;
    transition: opacity var(--dur) var(--ease);
  }

  /* Decorativo de la tarjeta de estadistica */
  .stat::after {
    content: "";
    position: absolute;
    inset-block-end: 0;
    inset-inline: 0;
    block-size: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      oklch(var(--orng-base)),
      transparent
    );
    opacity: 1;
    transition: opacity var(--dur) var(--ease);
  }

  /* Hover de la tarjeta de estadistica */
  .stat:hover {
    border-color: oklch(var(--orng-base) / 0.4);
    box-shadow: 0 8px 30px oklch(var(--orng-base) / 0.1);
  }

  /* Hover de la tarjeta de estadistica */
  .stat:hover::before {
    opacity: 1;
  }

  /* Hover de la tarjeta de estadistica */
  .stat:hover::after {
    opacity: 1;
  }

  /* Numero de la tarjeta de estadistica */
  .stat-num {
    font-family: var(--font-condensed);
    font-size: clamp(2rem, 4vw, 2.75rem);
    color: oklch(var(--orng-base));
    text-shadow: var(--glow-sm);
    line-height: 1;
    margin-block-end: var(--gap-mob-fld-1);
    letter-spacing: 0.02em;
  }

  /* Etiqueta de la tarjeta de estadistica */
  .stat-label {
    font-family: var(--font-condensed);
    font-size: 0.78rem;
    font-weight: 600;
    color: oklch(var(--white-base) / 0.6);
    line-height: 1.3;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  /* ═══════════════════════════════════════════
                    Tablet
  ═══════════════════════════════════════════ */

  @media (width >= 640px) {
    .about {
      padding-block-start: var(--pad-mob-fld-8);
    }

    .about-inner {
    }

    .about-title {
      margin-block-end: var(--mar-mob-fld-5);
    }

    .about-photo {
    }

    .about-photo-frame {
    }

    .img-main {
      inline-size: auto;
      block-size: auto;
      max-block-size: 40vh;
    }

    .stats-row {
      align-self: stretch;
    }

    .stat-num {
    }

    /* Contenedor de tarjetas about */
    .about-text {
      flex-direction: column;
      gap: var(--pad-mob-fld-3);
      justify-content: space-between;
      flex-wrap: wrap;
    }

    /* Tarjeta individual */
    .about-card {
      display: flex;
      gap: var(--pad-mob-fld-3);
      padding-block: var(--pad-mob-fld-1);
      padding-inline: var(--pad-mob-fld-2);
      background: oklch(var(--navy-800-base));
      border: 1px solid oklch(var(--orng-base) / 0.12);
      border-radius: var(--r-lg);
      position: relative;
      overflow: hidden;
      transition:
        border-color var(--dur) var(--ease),
        box-shadow var(--dur) var(--ease);
    }

    .about-card:last-child {
      inline-size: 100%;
    }

    /* Acento izquierdo naranja */
    .about-card::before {
      content: "";
      position: absolute;
      inset-block: 0;
      inset-inline-start: 0;
      inline-size: 2px;
      background: linear-gradient(
        to bottom,
        transparent,
        oklch(var(--orng-base)),
        transparent
      );
      opacity: 0.6;
      transition: opacity var(--dur) var(--ease);
    }

    .about-card:hover {
      border-color: oklch(var(--orng-base) / 0.3);
      box-shadow: 0 4px 24px oklch(var(--orng-base) / 0.08);
    }

    .about-card:hover::before {
      opacity: 1;
    }

    /* Icono */
    .about-card-icon {
      flex-shrink: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      inline-size: 2.5rem;
      block-size: 2.5rem;
      border-radius: var(--r-md);
      background: oklch(var(--orng-base) / 0.08);
      border: 1px solid oklch(var(--orng-base) / 0.2);
      color: oklch(var(--orng-base));
    }

    .about-card-icon svg {
      inline-size: 1.25rem;
      block-size: 1.25rem;
      filter: drop-shadow(0 0 4px oklch(var(--orng-base) / 0.5));
    }

    /* Título de tarjeta */
    .about-card-title {
      font-family: var(--font-condensed);
      font-size: var(--fs-txt-mob-fld-5);
      font-weight: var(--fntWght-semibold);
      color: oklch(var(--white-base));
      letter-spacing: 0.02em;
      margin-block-end: var(--gap-mob-fld-1);
      text-transform: uppercase;
    }

    /* Texto de tarjeta */
    .about-card-text {
      font-size: var(--fs-txt-mob-fld-3);
      color: oklch(var(--white-base) / 0.65);
      line-height: 1.6;
      text-wrap: pretty;
      margin-block-end: 0;
    }
  }

  /* ═══════════════════════════════════════════
                    Desktop
  ═══════════════════════════════════════════ */

  @media (width >= 920px) {
    /* Contenido principal */
    .about-inner {
      display: flex;
      flex-direction: row;
      justify-content: center;
    }

    /* Titulo principal */
    .about-title {
    }

    .about-photo {
      block-size: 100%;
      align-self: stretch;
      margin: 0;
    }

    .about-photo-frame {
    }

    .img-main {
      max-inline-size: 100%;
      max-block-size: 100%;
    }

    .stats-row {
    }

    .stat {
      max-inline-size: 300px;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
    }

    .stat-num {
      font-size: 3rem;
    }

    .stat-label {
      font-size: 1.2rem;
    }

    .about-text {
      display: flex;
      flex-direction: column;
      flex-wrap: nowrap;
      align-items: center;
      justify-content: space-evenly;
      padding: 0;
      margin: 0;
      gap: 1rem;
      max-inline-size: 500px;
    }

    .about-card {
      margin: 0;
    }

    .about-card-title {
      font-size: var(--fs-txt-mob-fld-7);
    }

    .about-card-text {
      font-size: var(--fs-txt-mob-fld-5);
      text-wrap: balance;
    }
  }
</style>
