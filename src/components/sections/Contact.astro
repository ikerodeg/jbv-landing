---
import Icon from "../ui/Icon.astro";
---

<section id="contacto" class="section contact" aria-label="Contacto">
  <p class="section-eyebrow contact-eyebrow reveal">Contacto</p>
  <div class="section-inner contact-inner">
    <h2 class="section-title contact-title reveal">
      Hablemos de su <span class="accent">próximo proyecto</span>
    </h2>
    <p class="section-lead contact-lead reveal">
      Cuéntenos qué necesita y le asesoraremos sin compromiso. La mejor grúa
      para su empresa puede estar en Alemania esperándole.
    </p>

    <div class="contact-grid">
      <!-- Left: Direct contact -->
      <div class="contact-info reveal">
        <h3>Contacto Directo</h3>
        <p>
          Preferimos hablar con usted directamente. Así entendemos mejor sus
          necesidades y podemos ofrecerle la solución más adecuada para su
          empresa.
        </p>

        <div class="contact-methods">
          <!-- TODO: Reemplazar el número de teléfono y WhatsApp ficticio (+34600000000) por los reales -->
          <a
            href="https://wa.me/34600000000"
            class="contact-cta"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Enviar mensaje por WhatsApp"
          >
            <div class="cta-ico wa" aria-hidden="true">
              <Icon name="whatsapp" />
            </div>
            <div class="cta-label">
              <strong>WhatsApp</strong>
              <span>Respuesta rápida</span>
            </div>
          </a>

          <a
            href="tel:+34600000000"
            class="contact-cta"
            aria-label="Llamar por teléfono"
          >
            <div class="cta-ico ph" aria-hidden="true">
              <Icon name="phone" />
            </div>
            <div class="cta-label">
              <strong>+34 600 000 000</strong>
              <span>Llamada directa</span>
            </div>
          </a>
        </div>
      </div>

      <div class="contact-form-container reveal reveal-delay-2">
        <form
          class="contact-form"
          id="contact-form"
          action="#"
          method="post"
          aria-label="Formulario de consulta"
          novalidate
        >
          <div class="form-row">
            <div class="form-field">
              <label for="nombre">Nombre *</label>
              <input
                type="text"
                id="nombre"
                name="nombre"
                placeholder="Su nombre"
                required
                autocomplete="name"
                inputmode="text"
              />
            </div>
            <div class="form-field">
              <label for="empresa">Empresa *</label>
              <input
                type="text"
                id="empresa"
                name="empresa"
                placeholder="Nombre de su empresa"
                required
                autocomplete="organization"
              />
            </div>
          </div>

          <div class="form-row">
            <div class="form-field">
              <label for="telefono">Teléfono *</label>
              <input
                type="tel"
                id="telefono"
                name="telefono"
                placeholder="+34 600 000 000"
                required
                autocomplete="tel"
                inputmode="tel"
              />
            </div>
            <div class="form-field">
              <label for="email">Email</label>
              <input
                type="email"
                id="email"
                name="email"
                placeholder="correo@empresa.com"
                autocomplete="email"
                inputmode="email"
              />
            </div>
          </div>

          <div class="form-field">
            <label for="mensaje">Mensaje / Tipo de grúa que busca</label>
            <textarea
              id="mensaje"
              name="mensaje"
              rows="5"
              placeholder="Describa qué tipo de grúa autopropulsada necesita: tonelaje, marca preferida, presupuesto orientativo, plazos..."
            ></textarea>
          </div>

          <div class="form-privacy">
            <input type="checkbox" id="privacidad" name="privacidad" required />
            <label for="privacidad">
              He leído y acepto la <a href="/privacidad"
                >Política de Privacidad</a
              > de JBV. Mis datos serán tratados para gestionar mi consulta.
            </label>
          </div>

          <!-- Honeypot anti-spam -->
          <input
            type="text"
            name="_honey"
            style="display:none"
            tabindex="-1"
            autocomplete="off"
            aria-hidden="true"
          />

          <div class="form-submit">
            <button type="submit" class="btn btn-primary">
              <Icon name="send" />
              Enviar Consulta
            </button>
          </div>
        </form>

        <div class="form-success" id="form-success" hidden aria-live="polite">
          <h3>¡Mensaje Enviado!</h3>
          <p>
            Gracias por contactarnos. Le responderemos lo antes posible,
            normalmente en menos de 24 horas.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById(
    "contact-form",
  ) as HTMLFormElement | null;
  const success = document.getElementById("form-success");

  const showError = (
    input: HTMLInputElement | HTMLTextAreaElement,
    message: string,
  ) => {
    const parent = input.closest(".form-field, .form-privacy");
    if (!parent) return;

    input.classList.add("invalid");
    let errorEl = parent.querySelector(".field-error");
    if (!errorEl) {
      errorEl = document.createElement("span");
      errorEl.className = "field-error";
      errorEl.setAttribute("aria-live", "polite");
      parent.appendChild(errorEl);
    }
    errorEl.textContent = message;
  };

  const clearErrors = () => {
    if (!form) return;
    form
      .querySelectorAll(".invalid")
      .forEach((el) => el.classList.remove("invalid"));
    form.querySelectorAll(".field-error").forEach((el) => el.remove());
  };

  const isValidEmail = (email: string) =>
    /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);

  form?.addEventListener("submit", (e) => {
    e.preventDefault();
    clearErrors();

    let isValid = true;
    const formData = new FormData(form);

    // Honeypot check
    if (formData.get("_honey")) return;

    const nombre = form.elements.namedItem("nombre") as HTMLInputElement;
    const empresa = form.elements.namedItem("empresa") as HTMLInputElement;
    const telefono = form.elements.namedItem("telefono") as HTMLInputElement;
    const email = form.elements.namedItem("email") as HTMLInputElement;
    const privacidad = form.elements.namedItem(
      "privacidad",
    ) as HTMLInputElement;

    if (!nombre.value.trim()) {
      showError(nombre, "El nombre es obligatorio");
      isValid = false;
    }

    if (!empresa.value.trim()) {
      showError(empresa, "La empresa es obligatoria");
      isValid = false;
    }

    if (!telefono.value.trim()) {
      showError(telefono, "El teléfono es requerido");
      isValid = false;
    }

    if (email.value.trim() && !isValidEmail(email.value.trim())) {
      showError(email, "Introduzca un email válido");
      isValid = false;
    }

    if (!privacidad.checked) {
      showError(privacidad, "Debe aceptar la política de privacidad");
      isValid = false;
    }

    if (!isValid) return;

    // In production: conect to FormSubmit, Netlify Forms, or email service
    form.hidden = true;
    if (success) success.hidden = false;
  });
</script>

<style>
  /* ═══════════════════════════════════════════
                  Mobile-first
  ═══════════════════════════════════════════ */

  .contact-grid {
    display: flex;
    flex-direction: column;
    gap: var(--mar-mob-fld-7);
    align-items: start;
  }

  .contact-info h3 {
    font-size: var(--fs-txt-mob-fld-1);
    font-weight: var(--fntWght-bold);
    letter-spacing: 0.04em;
    margin-block-end: var(--mar-mob-fld-3);
  }

  .contact-info > p {
    font-size: var(--fs-txt-mob-fld-1);
    color: oklch(var(--white-base) / 0.7);
    line-height: 1.7;
    margin-block-end: var(--mar-mob-fld-5);
  }

  .contact-methods {
    display: flex;
    gap: var(--gap-mob-fld-3);
  }

  .contact-cta {
    display: flex;
    align-items: center;
    justify-content: space-around;
    inline-size: 50%;
    padding-block: var(--padding-space-2);
    padding-inline: var(--padding-space-2);
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--r-md);
    text-decoration: none;
    transition: all var(--dur) var(--ease);
    gap: var(--padding-space-2);
  }

  .contact-cta:nth-child(1) {
    border: 1px solid oklch(var(--green-500-base));
  }

  .contact-cta:nth-child(2) {
    border: 1px solid oklch(var(--orange-500-base));
  }

  .contact-cta:hover {
    border-color: oklch(var(--orange-500-base) / 0.3);
    transform: translateX(4px);
  }

  .cta-ico {
    inline-size: 45px;
    block-size: 45px;
    padding: 0.3rem;
    border-radius: var(--r-md);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .cta-ico.wa {
    background: oklch(var(--green-500-base) / 0.15);
    color: oklch(var(--green-500-base));
  }

  .cta-ico.ph {
    background: oklch(var(--orange-500-base) / 0.15);
    color: oklch(var(--orange-500-base));
  }

  .cta-ico svg {
    inline-size: 22px;
    block-size: 22px;
  }

  .cta-label strong {
    display: block;
    font-family: var(--font-condensed);
    font-weight: 700;
    font-size: 0.95rem;
    color: var(--white);
    margin-block-end: var(--space-1);
  }

  .cta-label span {
    font-size: 0.82rem;
    color: var(--white-50);
  }

  /* Form */
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    inline-size: 100%;
  }

  .form-row {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .form-field {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .form-field label {
    font-family: var(--font-condensed);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--white-50);
  }

  .form-field input,
  .form-field textarea {
    padding-block: var(--space-4);
    padding-inline: var(--space-5);
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--r-md);
    color: var(--white);
    font-family: var(--font-body);
    font-size: 0.95rem;
    transition:
      border-color var(--dur) var(--ease),
      box-shadow var(--dur) var(--ease);
    outline: none;
    -webkit-appearance: none;
  }

  .form-field input::placeholder,
  .form-field textarea::placeholder {
    color: var(--navy-400);
  }

  .form-field input:focus,
  .form-field textarea:focus {
    border-color: var(--orange-500);
    box-shadow: 0 0 0 3px oklch(var(--orange-500-base) / 0.12);
  }

  .form-field input.invalid,
  .form-field textarea.invalid {
    border-color: var(--orange-500);
    background-color: oklch(var(--orange-500-base) / 0.05);
  }

  :global(.field-error) {
    color: var(--orange-500);
    font-size: 0.82rem;
    margin-block-start: var(--space-2);
    flex-basis: 100%;
  }

  .form-field textarea {
    min-block-size: 130px;
    resize: vertical;
  }

  .form-privacy {
    display: flex;
    font-size: 0.8rem;
    color: var(--white-50);
    gap: 0.5rem;
    margin-block-end: var(--margin-space-2);
  }

  .form-privacy input[type="checkbox"] {
    inline-size: 20px;

    margin-block-start: 2px;
    accent-color: var(--orange-500);
    flex-shrink: 0;
  }

  .form-privacy a {
    color: var(--orange-400);
    text-decoration: underline;
  }

  .form-success {
    text-align: center;
    padding-block: var(--space-10);
    padding-inline: var(--space-8);
    background: var(--surface);
    border: 1px solid oklch(var(--orange-500-base) / 0.2);
    border-radius: var(--r-lg);
  }

  .form-success h3 {
    font-family: var(--font-display);
    font-size: 1.8rem;
    color: var(--orange-500);
    margin-block-end: var(--space-4);
  }

  .form-success p {
    color: var(--white-50);
  }

  .form-submit {
    margin-inline: auto;
  }

  /* ═══════════════════════════════════════════
                    Tablet
  ═══════════════════════════════════════════ */

  @media (width >= 768px) {
    .contact-title {
      margin-block-end: var(--pad-mob-fld-4);
    }

    .contact-lead {
      font-size: var(--fs-txt-mob-fld-5);
      margin-block-end: var(--mar-mob-fld-6);
    }

    .contact-info h3 {
      font-size: var(--fs-txt-mob-fld-6);
    }

    .contact-info > p {
      font-size: var(--fs-txt-mob-fld-4);
      margin-block-end: var(--mar-mob-fld-5);
    }

    .contact-methods {
      display: flex;
      flex-direction: row;
      gap: var(--gap-mob-fld-5);
      justify-content: space-evenly;
    }

    .contact-cta {
      display: flex;
      inline-size: 250px;
      justify-content: center;
      gap: var(--gap-mob-fld-3);
    }

    .cta-ico {
      inline-size: 44px;
      block-size: 44px;
      border-radius: var(--r-md);
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }

    .cta-label strong {
      font-size: var(--fs-txt-mob-fld-6);
    }

    .cta-label span {
      font-size: var(--fs-txt-mob-fld-3);
    }

    .contact-form-container {
      inline-size: 100%;
      padding-block: var(--padding-space-3);
      padding-inline: var(--padding-space-3);
    }

    .contact-form {
      inline-size: 100%;
    }
  }

  /* ═══════════════════════════════════════════
                      Desktop
  ═══════════════════════════════════════════ */

  @media (width >= 1024px) {
    .contact {
      background: var(--navy-900);
    }

    .contact-grid {
      display: grid;
      grid-template-columns: 1fr 1.8fr;
      gap: 4rem;
      align-items: start;
    }

    .contact-info h3 {
      font-family: var(--font-condensed);
      font-size: var(--fs-txt-mob-fld-7);
      font-weight: 700;
      letter-spacing: 0.04em;
      color: var(--white);
      margin-block-end: var(--space-5);
    }

    .contact-info > p {
      font-size: var(--fs-txt-mob-fld-4);
      color: oklch(var(--white-base) / 0.8);
      line-height: 1.7;
      margin-block-end: var(--space-8);
    }

    .contact-methods {
      display: flex;
      flex-direction: column;
      gap: var(--gap-mob-fld-6);
    }

    .contact-cta {
      display: flex;
      inline-size: 50%;
      margin-inline: auto;
      align-items: center;
      justify-content: space-around;
      gap: 1rem;
      padding-block: var(--pad-mob-fld-2);
      padding-inline: var(--pad-mob-fld-2);
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--r-md);
      text-decoration: none;
      transition: all var(--dur) var(--ease);
    }

    .contact-cta:hover {
      border-color: oklch(var(--orange-500-base) / 0.3);
      transform: translateX(4px);
    }

    .cta-ico {
      inline-size: 54px;
      block-size: 54px;
      border-radius: var(--r-md);
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }

    .cta-ico.wa {
      background: oklch(var(--green-500-base) / 0.25);
      color: oklch(var(--green-500-base));
    }

    .cta-ico.ph {
      background: oklch(var(--orng-base) / 0.25);
      color: oklch(var(--orng-base));
    }

    .cta-ico svg {
      inline-size: 44px;
      block-size: 44px;
    }

    .cta-label strong {
      display: block;
      font-family: var(--font-condensed);
      font-weight: 700;
      font-size: var(--fs-txt-mob-fld-6);
      color: var(--white);
      margin-block-end: var(--space-1);
    }

    .cta-label span {
      font-size: var(--fs-txt-mob-fld-3);
      color: var(--white-50);
    }

    /* Form */
    .contact-form {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .form-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
    }

    .form-field {
      display: flex;
      flex-direction: column;
      gap: 0.4rem;
    }

    .form-field label {
      font-family: var(--font-condensed);
      font-size: var(--fs-txt-mob-fld-2);
      font-weight: var(--fntWght-semibold);
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: oklch(var(--white-base) / 0.7);
    }

    .form-field input,
    .form-field textarea {
      padding-block: var(--space-4);
      padding-inline: var(--space-5);
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--r-md);
      color: var(--white);
      font-family: var(--font-body);
      font-size: 0.95rem;
      transition:
        border-color var(--dur) var(--ease),
        box-shadow var(--dur) var(--ease);
      outline: none;
      -webkit-appearance: none;
    }

    .form-field input::placeholder,
    .form-field textarea::placeholder {
      color: var(--navy-400);
    }

    .form-field input:focus,
    .form-field textarea:focus {
      border-color: var(--orange-500);
      box-shadow: 0 0 0 3px oklch(var(--orange-500-base) / 0.12);
    }

    .form-field input.invalid,
    .form-field textarea.invalid {
      border-color: var(--orange-500);
      background-color: oklch(var(--orange-500-base) / 0.05);
    }

    :global(.field-error) {
      color: var(--orange-500);
      font-size: 0.82rem;
      margin-block-start: var(--space-2);
      flex-basis: 100%;
    }

    .form-field textarea {
      min-block-size: 130px;
      resize: vertical;
    }

    .form-privacy {
      display: flex;
      gap: var(--gap-mob-fld-4);
    }

    .form-privacy label {
      font-size: var(--fs-txt-mob-fld-2);
      color: oklch(var(--white-base) / 0.5);
    }

    .form-privacy input[type="checkbox"] {
      margin-block-start: 2px;
      accent-color: var(--orange-500);
      flex-shrink: 0;
    }

    .form-privacy a {
      color: var(--orange-400);
      text-decoration: underline;
    }

    .form-success {
      text-align: center;
      padding-block: var(--space-10);
      padding-inline: var(--space-8);
      background: var(--surface);
      border: 1px solid oklch(var(--orange-500-base) / 0.2);
      border-radius: var(--r-lg);
    }

    .form-success h3 {
      font-family: var(--font-display);
      font-size: 1.8rem;
      color: var(--orange-500);
      margin-block-end: var(--space-4);
    }

    .form-success p {
      color: var(--white-50);
    }
  }
</style>
