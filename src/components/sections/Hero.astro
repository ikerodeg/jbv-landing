---
import { getImage } from "astro:assets";
import Icon from "../ui/Icon.astro";
import bgCraneMobile from "../../assets/images/bg-crane-mobile2.webp";
import bgCraneDesktop from "../../assets/images/bg-crane.png";

const mobile = await getImage({ src: bgCraneMobile });
const desktop = await getImage({ src: bgCraneDesktop });
---

<section id="inicio" class="hero" aria-label="Inicio">
  <!-- Background image -->
  <div class="hero-bg" aria-hidden="true">
    <picture>
      <source media="(min-width: 640px)" srcset={desktop.src} />
      <img src={mobile.src} alt="" fetchpriority="high" decoding="async" />
    </picture>
  </div>

  <!-- Gradient mask -->
  <div class="hero-mask" aria-hidden="true"></div>

  <!-- Content -->
  <div class="hero-content">
    <h1 class="hero-title">JBV</h1>
    <h2 class="hero-subtitle">
      Intermediación Profesional<br />de Grúas Autopropulsadas
    </h2>

    <div class="hero-badge">
      <span>Alemania · España</span>
    </div>

    <p class="hero-desc">
      Conectamos su empresa con las mejores grúas autopropulsadas del mercado
      alemán. Transparencia, fiabilidad y el mejor precio.
    </p>

    <div class="hero-ctas">
      <!-- TODO: Reemplazar el número de teléfono y WhatsApp ficticio (+34600000000) por los reales -->
      <a
        href="https://wa.me/34600000000"
        class="btn btn-whatsapp"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Contactar por WhatsApp"
      >
        <Icon name="whatsapp" />
        WhatsApp
      </a>

      <a
        href="tel:+34600000000"
        class="btn btn-outline"
        aria-label="Llamar por teléfono"
      >
        <Icon name="phone" />
        Llamar ahora
      </a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="hero-scroll" aria-hidden="true">
    <span>Scroll</span>
    <div class="scroll-line"></div>
  </div>
</section>

<style>
  /* ═══════════════════════════════════════════
     Base / Mobile-first
     ═══════════════════════════════════════════ */

  .hero {
    position: relative;
    min-block-size: 100svh;
    display: flex;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-bg img {
    inline-size: 100%;
    block-size: 100%;
    object-fit: cover;
    object-position: 20% center;
  }

  .hero-mask {
    position: absolute;
    block-size: 100svh;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      to top,
      oklch(8.774% 0.03127 257.112 / 0.849) 10%,
      oklch(8.774% 0.03127 257.112 / 0.925) 20%,
      oklch(8.774% 0.03127 257.112 / 0.747) 35%,
      oklch(8.774% 0.03127 257.112 / 0.664) 95%,
      transparent 100%
    );
  }

  /* Bottom fade */
  .hero-mask::after {
    content: "";
    position: absolute;
    inset-block-end: 0;
    inset-inline: 0;
    block-size: 6rem;
    background: linear-gradient(to top, var(--bg), transparent);
  }

  .hero-content {
    inline-size: 100%;
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: var(--gap-mobile-fluid-1);
    align-items: center;
    z-index: 2;
    padding-inline: var(--padding-space-3);
    text-align: center;
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: var(--fs-mobile-fluid-1);
    font-weight: 400;
    line-height: 0.85;
    color: white;
    text-shadow:
      0 0 10px orange,
      1px 1px 6px black;
    animation: fadeUp 0.7s 0.2s var(--ease) both;
  }

  .hero-subtitle {
    font-family: var(--font-condensed);
    font-size: var(--fs-mobile-fluid-2);
    font-weight: 600;
    color: rgba(255, 166, 0, 0.712);
    text-shadow:
      0 0 2px rgba(255, 255, 255, 0.445),
      0 0 2px black;
    line-height: 1.5;
    animation: fadeUp 0.7s 0.3s var(--ease) both;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: var(--padding-space-2);
    padding-inline: var(--padding-space-3);
    padding-block: var(--padding-space-2);
    border: 1px solid oklch(var(--orange-500-base) / 0.35);
    border-radius: 100px;
    background: oklch(0% 0 0 / 0.37);
    font-family: var(--font-condensed);
    font-size: var(--fs-mobile-fluid-3);
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--orange-400);
    animation: fadeUp 0.7s 0.1s var(--ease) both;
  }

  .hero-badge::before {
    content: "";
    inline-size: 6px;
    block-size: 6px;
    border-radius: 50%;
    background: var(--orange-500);
    box-shadow: var(--glow-sm);
    animation: pulse 2s infinite;
  }

  .hero-desc {
    font-size: var(--fs-mobile-fluid-4);
    font-weight: 600;
    color: var(--white-50);
    line-height: 1.55;
    max-inline-size: 38ch;
    margin-block-end: var(--margin-mobile-fluid-1);
    animation: fadeUp 0.7s 0.4s var(--ease) both;
  }

  .hero-ctas {
    margin-inline: auto;
    inline-size: 100%;
    display: flex;
    flex-wrap: wrap;
    gap: var(--gap-mobile-fluid-1);
    animation: fadeUp 0.7s 0.5s var(--ease) both;
    justify-content: center;
  }

  /* Scroll indicator — oculto en mobile */
  .hero-scroll {
    display: none;
  }

  /* ═══════════════════════════════════════════
     Desktop overrides (solo diferencias)
     ═══════════════════════════════════════════ */

  @media (width >= 640px) {
    .hero {
      align-items: center;
    }

    .hero-bg img {
      object-position: 65% center;
    }

    .hero-mask {
      background: linear-gradient(
        100deg,
        oklch(0.09 0.03 252 / 0.98) 0%,
        oklch(0.09 0.03 252 / 0.92) 25%,
        oklch(0.09 0.03 252 / 0.65) 45%,
        oklch(0.09 0.03 252 / 0.25) 65%,
        oklch(0.09 0.03 252 / 0.05) 80%,
        transparent 100%
      );
    }

    .hero-mask::after {
      block-size: 12.5rem;
    }

    .hero-content {
      inline-size: fit-content;
      padding-inline: 0;
      padding-block: 0;
      margin-inline-start: clamp(4rem, 10vw, 12rem);
    }

    .hero-title {
      font-size: 20rem;
    }

    .hero-subtitle {
      font-size: 3rem;
      letter-spacing: 0.05em;
      margin-block-end: var(--margin-space-2);
    }

    .hero-badge {
      padding-inline: var(--padding-space-3);
      padding-block: var(--padding-space-2);
      background: oklch(var(--orange-500-base) / 0.08);
      font-size: 0.75rem;
      margin-block-end: var(--margin-space-2);
    }

    .hero-desc {
      font-size: clamp(0.9rem, 1.5vw, 1rem);
      color: var(--white-50);
      line-height: 1.7;
      max-inline-size: 520px;
      margin-block-end: var(--margin-space-5);
    }

    .hero-ctas {
      gap: var(--margin-space-3);
    }

    .hero-scroll {
      display: flex;
      position: absolute;
      inset-block-end: 2.5rem;
      inset-inline-start: 50%;
      transform: translateX(-50%);
      z-index: 2;
      flex-direction: column;
      align-items: center;
      gap: 0.5rem;
      color: var(--white-50);
      font-family: var(--font-condensed);
      font-size: 0.7rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      animation: fadeIn 1s 1.2s both;
    }

    .scroll-line {
      inline-size: 1px;
      block-size: 50px;
      background: linear-gradient(to bottom, var(--orange-500), transparent);
      animation: scrollLine 1.5s ease-in-out infinite;
    }
  }
</style>
