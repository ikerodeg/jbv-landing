---
import { getImage } from "astro:assets";
import Icon from "../ui/Icon.astro";
import bgCraneMobile from "../../assets/images/bg-crane-mobile4.webp";
import bgCraneTablet from "../../assets/images/bg-crane-tablet1.webp";
import bgCraneDesktop from "../../assets/images/bg-crane-desk4.webp";

const mobile = await getImage({ src: bgCraneMobile });
const tablet = await getImage({ src: bgCraneTablet });
const desktop = await getImage({ src: bgCraneDesktop });
---

<section id="inicio" class="hero" aria-label="Inicio">
  <!-- Background image -->
  <div class="hero-bg" aria-hidden="true">
    <picture>
      <source media="(min-width: 920px)" srcset={desktop.src} />
      <source media="(min-width: 640px)" srcset={tablet.src} />
      <img src={mobile.src} alt="" fetchpriority="high" decoding="async" />
    </picture>
  </div>

  <!-- Gradient mask -->
  <div class="hero-mask" aria-hidden="true"></div>

  <!-- Content -->
  <div class="hero-content">
    <h1 class="hero-title">JBV</h1>
    <h2 class="hero-subtitle">
      Intermediación Profesional<br />de Grúas Autopropulsadas
    </h2>

    <div class="hero-badge">
      <span>🇩🇪 Alemania <span class="dot"></span> España 🇪🇦</span>
    </div>

    <p class="hero-desc">
      Conectamos su empresa con las mejores grúas autopropulsadas del mercado
      alemán. Transparencia, fiabilidad y el mejor precio.
    </p>

    <div class="hero-ctas">
      <!-- TODO: Reemplazar el número de teléfono y WhatsApp ficticio (+34600000000) por los reales -->
      <a
        href="https://wa.me/34600000000"
        class="btn btn-whatsapp"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Contactar por WhatsApp"
      >
        <Icon name="whatsapp" />
        WhatsApp
      </a>

      <a
        href="tel:+34600000000"
        class="btn btn-llamar"
        aria-label="Llamar por teléfono"
      >
        <Icon name="phone" />
        Llamar ahora
      </a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="hero-scroll" aria-hidden="true">
    <span>Scroll</span>
    <div class="scroll-line"></div>
  </div>
</section>

<style>
  /* ═══════════════════════════════════════════
                    Mobile-first
     ═══════════════════════════════════════════ */

  .hero {
    position: relative;
    min-block-size: 100svh;
    display: flex;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-bg img {
    inline-size: 100%;
    block-size: 100%;
    object-fit: cover;
  }

  .hero-mask {
    position: absolute;
    block-size: 100svh;
    inset: 0;
    z-index: 1;
    background-image: linear-gradient(
      to bottom,
      oklch(var(--black-base) / 0.9) 0%,
      oklch(var(--black-base) / 0.6) 20%,
      oklch(var(--black-base) / 0.5) 40%,
      oklch(var(--black-base) / 0.2) 60%,
      oklch(var(--black-base) / 0.3) 80%,
      oklch(var(--black-base) / 0.7) 90%,
      oklch(var(--black-base) / 1) 100%
    );
  }

  .hero-content {
    inline-size: 100%;
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: var(--gap-mob-fld-7);
    align-items: center;
    z-index: 2;
    padding-inline: var(--pad-mob-fld-3);
    text-align: center;
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: var(--fs-ttl-mob-fld-1);
    font-weight: var(--fntWght-light);
    line-height: 0.85;
    color: oklch(var(--white-accent));
    text-shadow:
      0px 0px 20px oklch(var(--orng-base)),
      0px 0px 10px oklch(var(--orng-accent)),
      1px 1px 5px oklch(var(--black-base));
    animation: fadeUp 0.7s 0.2s var(--ease) both;
  }

  .hero-subtitle {
    font-size: var(--fs-txt-mob-fld-10);
    font-weight: var(--fntWght-semibold);
    color: oklch(var(--orng-base));
    text-shadow:
      0 0 40px oklch(var(--black-base)),
      1px 1px 5px oklch(var(--black-base));
    line-height: 1.5;
    margin-block-start: calc(var(--gap-mob-fld-8) * -0.75);
    animation: fadeUp 0.7s 0.3s var(--ease) both;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: var(--gap-mob-fld-2);
    padding-inline: var(--pad-mob-fld-2);
    padding-block: var(--pad-mob-fld-1);
    border: 1px solid oklch(var(--orng-accent));
    border-radius: 0.8em;
    background: oklch(var(--black-base) / 0.7);
    font-size: var(--fs-txt-mob-fld-1);
    font-weight: var(--fntWght-semibold);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: oklch(var(--orng-accent) / 0.9);
    animation: fadeUp 0.7s 0.1s var(--ease) both;
  }

  .dot {
    display: inline-block;
    margin-inline: var(--mar-mob-fld-1);
    inline-size: 6px;
    block-size: 6px;
    border-radius: 50%;
    background: oklch(var(--orng-base));
    box-shadow: var(--glow-sm);
    animation: pulse 2s infinite;
  }

  .hero-desc {
    filter: drop-shadow(0px 0px 10px oklch(var(--black-base)));
    font-size: var(--fs-txt-mob-fld-3);
    font-weight: var(--fntWght-medium);
    color: oklch(var(--white-base) / 0.8);
    text-shadow: 1px 1px 2px oklch(var(--black-base));
    line-height: 1.55;
    max-inline-size: 35ch;
    margin-block-end: var(--mar-mob-fld-5);
    animation: fadeUp 0.7s 0.4s var(--ease) both;
  }

  .hero-ctas {
    margin-inline: auto;
    inline-size: 100%;
    display: flex;
    flex-wrap: wrap;
    gap: var(--gap-mob-fld-5);
    animation: fadeUp 0.7s 0.5s var(--ease) both;
    justify-content: center;
  }

  .btn {
    inline-size: 150px;
  }

  .btn-whatsapp {
    color: oklch(var(--green-500-base));
    box-shadow: 0 0 10px oklch(var(--green-500-base) / 0.35);
    border: 1px solid oklch(var(--green-500-base) / 0.5);
  }

  .btn-whatsapp::before {
    background: conic-gradient(from 0deg, #34a500, #51ff00, #267700);
    animation: rotate 4s linear infinite;
  }

  .btn-whatsapp:hover {
    background: oklch(0.68 0.18 155);
    box-shadow:
      0 0 20px oklch(var(--green-500-base) / 0.4),
      0 0 60px oklch(var(--green-500-base) / 0.3),
      0 0 100px oklch(var(--green-500-base) / 0.1);
    transform: translateY(-2px);
  }

  .btn-llamar {
    color: oklch(var(--orng-accent));
    box-shadow: 0 0 10px oklch(var(--orng-accent) / 0.35);
    border: 1px solid oklch(var(--orng-accent));
  }

  .btn-llamar:hover {
    background: var(--orng-base);
    box-shadow:
      0 0 20px oklch(var(--orng-accent) / 0.4),
      0 0 60px oklch(var(--orng-accent) / 0.3),
      0 0 100px oklch(var(--orng-accent) / 0.1);
    transform: translateY(-2px);
  }

  /* Scroll indicator — oculto en mobile */
  .hero-scroll {
    display: none;
  }

  /* ═══════════════════════════════════════════
                  Tablet
  ═══════════════════════════════════════════ */

  @media (width >= 640px) {
    .hero-title {
      font-size: var(--fs-ttl-mob-fld-10);
      filter: drop-shadow(0px 0px 10px oklch(var(--black-base)));
    }

    .hero-subtitle {
      font-size: calc(var(--fs-txt-mob-fld-10) * 1.3);
      filter: drop-shadow(0px 0px 10px oklch(var(--black-base)));
    }

    .hero-desc {
      background-color: oklch(var(--black-base) / 0.2);
      font-size: calc(var(--fs-txt-mob-fld-10) * 0.8);
    }

    .hero-badge {
      font-size: var(--fs-txt-mob-fld-3);
    }

    .hero-badge::before {
      inline-size: 8px;
      block-size: 8px;
    }

    .hero-ctas {
      gap: var(--mar-mob-fld-10);
    }

    .btn {
      inline-size: 250px;
      font-size: var(--fs-txt-mob-fld-4);
    }

    .hero-scroll {
      display: flex;
      position: absolute;
      inset-block-end: 2.5rem;
      inset-inline-start: 50%;
      transform: translateX(-50%);
      z-index: 2;
      flex-direction: column;
      align-items: center;
      gap: 0.5rem;
      color: var(--white-50);
      font-family: var(--font-condensed);
      font-size: 0.7rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      animation: fadeIn 1s 1.2s both;
    }

    .scroll-line {
      inline-size: 1px;
      block-size: 30px;
      background: linear-gradient(to bottom, var(--orange-500), transparent);
      animation: scrollLine 1.5s ease-in-out infinite;
    }
  }

  /* ═══════════════════════════════════════════
                    Desktop
     ═══════════════════════════════════════════ */

  @media (width >= 920px) {
    .hero {
      position: relative;
      padding-inline: var(--pad-mob-fld-3);
      padding-block-start: var(--pad-mob-fld-8);
      align-items: center;
      justify-content: flex-start;
    }
    .hero-bg img {
      margin-inline: auto;
      object-position: 65% center;
    }

    .hero-mask {
      position: absolute;
      block-size: 100svh;
      inset: 0;
      z-index: 1;
    }

    .hero-mask::after {
      content: "";
      position: absolute;
      inset: 0;
      z-index: 5;
      background-image: linear-gradient(to right, black 8%, transparent 60%);
    }

    .hero-content {
      max-inline-size: 55vw;
      padding-inline-start: var(--pad-mob-fld-9);
      padding-block: 0;
      justify-content: center;
      align-items: center;
      gap: var(--gap-mob-fld-6);
    }

    .hero-ctas {
      inline-size: 40vw;
      block-size: 100%;
      padding-block: var(--pad-mob-fld-7);
      position: absolute;
      inset-inline-start: 100%;
      align-items: center;
      align-content: space-between;
      justify-content: center;
      transform: none;
    }

    .btn {
      block-size: 80px;
    }

    .hero-scroll {
      inset-block-end: 1.5rem;
      inset-inline-start: 55%;
    }
  }
</style>
