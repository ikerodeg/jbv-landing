---
import { steps } from "@data/steps";
---

<section id="proceso" class="section process" aria-label="Proceso de compra">
  <div class="section-eyebrow process-eyebrow reveal">Proceso de Compra</div>
  <div class="section-inner process-inner">
    <div class="section-header process-header reveal">
      <h2 class="section-title process-title">
        Cinco pasos hacia<br />su <span class="accent">grúa ideal</span>
      </h2>
      <p class="section-lead process-lead">
        Un proceso sencillo, transparente y diseñado para que usted solo tome la
        decisión final. Nosotros nos encargamos de todo lo demás.
      </p>
    </div>

    <div class="process-track reveal" role="list">
      {
        steps.map((step, i) => (
          <div
            class={`process-step reveal reveal-delay-${i + 1}`}
            role="listitem"
          >
            <div class="step-aside" aria-hidden="true">
              <div class="step-num">{step.num}</div>
            </div>
            <div class="step-body">
              <h3>{step.title}</h3>
              <p>{step.desc}</p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  /* ═══════════════════════════════════════════
                    Mobile-first
    ═══════════════════════════════════════════ */

  /* Seccion Process */
  .process-inner {
    display: flex;
    flex-direction: column;
  }

  .process-lead {
    color: oklch(var(--white-base) / 0.7);
  }

  /* Track */
  .process-track {
    display: flex;
    flex-direction: column;
    gap: var(--pad-mob-fld-6);
  }

  /* Step */
  .process-step {
    display: flex;
    align-items: flex-start;
    gap: var(--pad-mob-fld-3);
    padding-block: var(--pad-mob-fld-1);
    padding-inline: var(--pad-mob-fld-2);
    background: oklch(var(--navy-800-base));
    border: 1px solid oklch(var(--orng-base) / 0.12);
    border-radius: var(--r-lg);
    position: relative;
    overflow: hidden;
    transition:
      border-color var(--dur) var(--ease),
      box-shadow var(--dur) var(--ease);
  }

  .process-step::before {
    content: "";
    position: absolute;
    inset-block: 0;
    inset-inline-start: 0;
    inline-size: 2px;
    background: linear-gradient(
      to bottom,
      transparent,
      oklch(var(--orng-base)),
      transparent
    );
    opacity: 0.6;
    transition: opacity var(--dur) var(--ease);
  }

  .process-step::after {
    content: "";
    position: absolute;
    inset-block: 0;
    inset-inline-end: 0;
    inline-size: 2px;
    background: linear-gradient(
      to bottom,
      transparent,
      oklch(var(--orng-base)),
      transparent
    );
    opacity: 0.6;
    transition: opacity var(--dur) var(--ease);
  }

  .step-aside {
    padding-block-start: 0.5vh;
  }

  .step-num {
    inline-size: 48px;
    block-size: 48px;
    border-radius: 50%;
    border: 2px solid oklch(var(--orng-base) / 0.5);
    background: oklch(var(--orng-base) / 0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: var(--fs-txt-mob-fld-6);
    color: oklch(var(--orng-base));
    text-shadow: var(--glow-sm);
    transition: all var(--dur) var(--ease);
  }

  .process-step:hover {
    border-color: oklch(var(--orng-base) / 0.3);
    box-shadow: 0 4px 24px oklch(var(--orng-base) / 0.08);
  }

  .process-step:hover .step-num {
    border-color: var(--orng-base);
    box-shadow: var(--glow-sm);
    background: oklch(var(--orng-base) / 0.1);
  }

  .step-body h3 {
    font-size: var(--fs-txt-mob-fld-1);
    font-weight: var(--fntWght-bold);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: oklch(var(--white-base));
    margin-block-end: calc(var(--gap-mob-fld-1) - 0.6rem);
  }

  .step-body p {
    font-size: 0.85rem;
    color: oklch(var(--white-base) / 0.6);
    line-height: 1.6;
  }

  /* ═══════════════════════════════════════════
                    Tablet
  ═══════════════════════════════════════════ */

  @media (width >= 640px) {
    .process-title {
      margin-block-end: var(--pad-mob-fld-4);
    }

    .process-lead {
      font-size: var(--fs-txt-mob-fld-5);
    }

    .step-body h3 {
      font-size: var(--fs-txt-mob-fld-3);
    }

    .step-body p {
      font-size: var(--fs-txt-mob-fld-3);
      color: oklch(var(--white-base) / 0.6);
      line-height: 1.6;
    }
  }

  /* ═══════════════════════════════════════════
                      Desktop
  ═══════════════════════════════════════════ */

  @media (width >= 920px) {
    .process {
      background: var(--navy-800);
    }

    .process-inner {
      margin-block-end: var(--mar-mob-fld-6);
    }

    .process-header {
    }

    .process-track {
      inline-size: fit-content;
      margin-inline: auto;
      justify-content: center;
      align-items: center;
      overflow: visible;
      gap: var(--gap-mob-fld-8);
    }

    .process-lead {
      font-size: var(--fs-txt-mob-fld-5);
      color: var(--white-50);
      max-inline-size: 60%;
      margin-block-end: var(--mar-mob-fld-10);
    }

    .process-track {
      position: relative;
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .process-step {
      max-inline-size: 70%;
      display: flex;
      flex-direction: row;
      align-items: center;
      padding-block: var(--pad-mob-fld-5);
      padding-inline: var(--pad-mob-fld-3);
    }

    .process-step:last-child {
    }

    .step-aside {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0;
    }

    .step-num {
      inline-size: 56px;
      block-size: 56px;
      border-radius: 50%;
      border: 2px solid oklch(var(--orange-500-base) / 0.4);
      background: oklch(var(--orange-500-base) / 0.08);
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: var(--font-display);
      font-size: 1.4rem;
      color: var(--orange-500);
      text-shadow: var(--glow-sm);
      flex-shrink: 0;
      transition: all var(--dur) var(--ease);
    }

    .process-step:hover .step-num {
      border-color: var(--orange-500);
      box-shadow: var(--glow-sm);
      background: oklch(var(--orange-500-base) / 0.15);
    }

    .step-line {
      flex: 1;
      inline-size: 1px;
      background: linear-gradient(
        to bottom,
        oklch(var(--orange-500-base) / 0.3),
        oklch(var(--orange-500-base) / 0.05)
      );
      margin-block-start: var(--space-3);
    }

    .process-step:last-child .step-line {
      display: none;
    }

    .step-body {
      padding-block: var(--space-4) 0;
    }

    .step-body h3 {
      font-family: var(--font-condensed);
      font-size: 1.75rem;
      font-weight: 700;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      color: var(--white);
      margin-block-end: var(--space-3);
    }

    .step-body p {
      font-size: 1.25rem;
      color: var(--white-50);
      line-height: 1.65;
    }
  }
</style>
