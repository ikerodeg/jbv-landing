---
import { services } from "@data/services";
---

<section id="servicios" class="section services" aria-label="Lo que hacemos">
  <div class="section-eyebrow reveal services-eyebrow">Lo Que Hacemos</div>
  <div class="section-inner services-inner">
    <h2 class="section-title reveal services-title">
      Intermediación <span class="accent">profesional</span>
    </h2>
    <p class="section-lead services-lead reveal">
      Facilitamos la compra de grúas autopropulsadas de origen alemán para
      empresas españolas. Un servicio integral basado en la confianza, la
      experiencia y el trato directo.
    </p>

    <div class="services-grid">
      {
        services.map((s, i) => (
          <article class={`card updown reveal reveal-delay-${(i % 3) + 1}`}>
            <header class="card-header">
              <div class="card-icon" aria-hidden="true">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                  aria-hidden="true"
                >
                  <Fragment set:html={s.icon} />
                </svg>
              </div>
              <h3 class="card-title">{s.title}</h3>
            </header>
            <p class="card-text">{s.desc}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  /* ═══════════════════════════════════════════
                    Mobile-first
  ═══════════════════════════════════════════ */

  .services {
    background: var(--navy-900);
  }

  .services-grid {
    display: flex;
    flex-direction: column;
    margin-inline: auto;
    max-inline-size: 85vw;
    gap: var(--gap-mobile-fluid-1);
  }

  /* ═══════════════════════════════════════════
                    Tablet
  ═══════════════════════════════════════════ */

  @media (width >= 640px) {
    .services-title {
      margin-block-end: var(--pad-mob-fld-4);
    }

    .services-lead {
      font-size: var(--fs-txt-mob-fld-5);
      margin-block-end: var(--mar-mob-fld-6);
    }

    .services-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: var(--pad-mob-fld-8) var(--pad-mob-fld-5);
      margin-block-end: var(--mar-mob-fld-6);
      /* reset de los valores mobile */
      max-inline-size: none;
      margin-inline: 0;
    }

    .service-card p {
      font-size: var(--fs-txt-mob-fld-3);
    }
  }

  /* ═══════════════════════════════════════════
                    Desktop
  ═══════════════════════════════════════════ */

  @media (width >= 920px) {
    .services {
      background: var(--navy-900);
    }

    .services-lead {
      inline-size: 80ch;
      font-size: var(--fs-txt-mob-fld-6);
      margin-block-end: var(--mar-mob-fld-6);
    }

    .services-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: var(--gap-mob-fld-5);
    }

    .card-title {
      font-size: var(--fs-txt-mob-fld-6);
      margin-block-end: var(--gap-mob-fld-1);
    }

    .card-text {
      font-size: var(--fs-txt-mob-fld-4);
      text-wrap: balance;
    }

    .card-icon {
      inline-size: 44px;
      block-size: 44px;
    }

    .card-icon svg {
      inline-size: 36px;
      block-size: 36px;
    }
  }
</style>
