---
import { reasons } from "@data/reasons";
---

<section id="por-que" class="section why-us" aria-label="Por qué elegirnos">
  <p class="section-eyebrow why-us-eyebrow reveal">Por Qué Elegirnos</p>
  <div class="section-inner why-us-inner">
    <h2 class="section-title why-us-title reveal">
      Su <span class="accent">experto</span><br />de confianza
    </h2>
    <p class="section-lead why-us-lead reveal">
      No somos un intermediario más. Somos su extensión en Alemania, con la
      experiencia y los contactos para conseguirle la mejor maquinaria al mejor
      precio.
    </p>

    <div class="why-grid">
      {
        reasons.map((r, i) => (
          <article class={`why-card reveal reveal-delay-${(i % 3) + 1}`}>
            <div class="why-icon" aria-hidden="true">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="1.8"
              >
                <Fragment set:html={r.icon} />
              </svg>
            </div>
            <div>
              <h3>{r.title}</h3>
              <p>{r.desc}</p>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  /* ═══════════════════════════════════════════
                    Mobile-first
  ═══════════════════════════════════════════ */

  .why-grid {
    display: flex;
    flex-direction: column;
    gap: var(--mar-mob-fld-5);
  }

  .why-card {
    display: flex;
    gap: var(--gap-mob-fld-3);
    padding-block: var(--pad-mob-fld-2);
    padding-inline: var(--pad-mob-fld-2);
    background: oklch(var(--navy-800-base));
    border: 1px solid var(--white-08);
    border-radius: var(--r-lg);
    transition: all var(--dur) var(--ease);
  }

  /* Decorativo de la tarjeta de estadistica */
  .why-card::before {
    content: "";
    position: absolute;
    inset-block-start: 0;
    inset-inline: 0;
    block-size: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      oklch(var(--orng-base)),
      transparent
    );
    opacity: 1;
    transition: opacity var(--dur) var(--ease);
  }

  /* Decorativo de la tarjeta de estadistica */
  .why-card::after {
    content: "";
    position: absolute;
    inset-block-end: 0;
    inset-inline: 0;
    block-size: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      oklch(var(--orng-base)),
      transparent
    );
    opacity: 1;
    transition: opacity var(--dur) var(--ease);
  }

  .why-card:hover {
    border-color: oklch(var(--orng-base) / 0.2);
    background: oklch(var(--navy-700-base));
    transform: translateY(-2px);
  }

  .why-icon {
    flex-shrink: 0;
    inline-size: 44px;
    block-size: 44px;
    border-radius: var(--r-md);
    background: oklch(var(--orng-base) / 0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    color: oklch(var(--orng-base));
  }

  .why-icon svg {
    inline-size: var(--fs-txt-mob-fld-7);
    block-size: var(--fs-txt-mob-fld-7);
  }

  .why-card h3 {
    font-size: var(--fs-txt-mob-fld-1);
    font-weight: var(--fntWght-bold);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: oklch(var(--white-base));
    margin-block-end: 0.35rem;
  }

  .why-card p {
    font-size: calc(var(--fs-txt-mob-fld-1) - 0.1rem);
    color: oklch(var(--white-base) / 0.5);
    line-height: 1.6;
  }

  /* ═══════════════════════════════════════════
                    Tablet
  ═══════════════════════════════════════════ */

  @media (width >= 768px) {
    .why-us-title {
      margin-block-end: var(--pad-mob-fld-4);
    }

    .why-us-lead {
      font-size: var(--fs-txt-mob-fld-5);
    }

    .why-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: var(--pad-mob-fld-6) var(--pad-mob-fld-5);
      margin-block-end: var(--mar-mob-fld-6);
    }

    .why-card p {
      font-size: var(--fs-txt-mob-fld-3);
    }
  }

  /* ═══════════════════════════════════════════
                    Desktop
  ═══════════════════════════════════════════ */

  @media (width >= 1024px) {
    .why-us {
      background: var(--navy-900);
    }

    .why-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 1rem;
    }

    .why-card {
      display: flex;
      gap: 1.25rem;
      padding-block: var(--space-7);
      padding-inline: var(--space-7);
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--r-lg);
      transition: all var(--dur) var(--ease);
    }

    .why-card:hover {
      border-color: oklch(var(--orange-500-base) / 0.2);
      background: var(--surface-2);
      transform: translateY(-2px);
    }

    .why-icon {
      flex-shrink: 0;
      inline-size: 44px;
      block-size: 44px;
      border-radius: var(--r-md);
      background: oklch(var(--orange-500-base) / 0.1);
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--orange-500);
    }

    .why-icon svg {
      inline-size: 22px;
      block-size: 22px;
    }

    .why-card h3 {
      font-family: var(--font-condensed);
      font-size: 1rem;
      font-weight: 700;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      color: var(--white);
      margin-block-end: 0.35rem;
    }

    .why-card p {
      font-size: 0.88rem;
      color: var(--white-50);
      line-height: 1.6;
    }
  }
</style>
