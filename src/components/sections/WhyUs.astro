---
import { reasons } from "@data/reasons";
---

<section id="por-que" class="section why-us" aria-label="Por qué elegirnos">
  <p class="section-eyebrow why-us-eyebrow reveal">Por Qué Elegirnos</p>
  <div class="section-inner why-us-inner">
    <h2 class="section-title why-us-title reveal">
      Su <span class="accent">experto</span> de confianza
    </h2>
    <p class="section-lead why-us-lead reveal">
      No somos un intermediario más. Somos su extensión en Alemania, con la
      experiencia y los contactos para conseguirle la mejor maquinaria al mejor
      precio.
    </p>

    <div class="why-grid">
      {
        reasons.map((r, i) => (
          <article class={`card updown reveal reveal-delay-${(i % 3) + 1}`}>
            <header class="card-header">
              <div class="card-icon" aria-hidden="true">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="1.8"
                >
                  <Fragment set:html={r.icon} />
                </svg>
              </div>
              <h3 class="card-title">{r.title}</h3>
            </header>
            <p class="card-text">{r.desc}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  /* ═══════════════════════════════════════════
                    Mobile-first
  ═══════════════════════════════════════════ */

  .why-grid {
    display: flex;
    flex-direction: column;
    gap: var(--mar-mob-fld-5);
  }

  /* ═══════════════════════════════════════════
                    Tablet
  ═══════════════════════════════════════════ */

  @media (width >= 640px) {
    .why-us-title {
      margin-block-end: var(--pad-mob-fld-4);
    }

    .why-us-lead {
      font-size: var(--fs-txt-mob-fld-5);
    }

    .why-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: var(--pad-mob-fld-6) var(--pad-mob-fld-5);
      margin-block-end: var(--mar-mob-fld-6);
    }

    .why-card p {
      font-size: var(--fs-txt-mob-fld-3);
    }
  }

  /* ═══════════════════════════════════════════
                    Desktop
  ═══════════════════════════════════════════ */

  @media (width >= 920px) {
    .why-us-title {
    }

    .why-us-lead {
    }

    .why-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: var(--gap-mob-fld-5);
    }

    .card-title {
      font-size: var(--fs-txt-mob-fld-6);
      margin-block-end: var(--gap-mob-fld-1);
