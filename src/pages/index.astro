---
import { getImage } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/layout/Navbar.astro";
import Hero from "../components/sections/Hero.astro";
import About from "../components/sections/About.astro";
import Services from "../components/sections/Services.astro";
import Process from "../components/sections/Process.astro";
import WhyUs from "../components/sections/WhyUs.astro";
import Contact from "../components/sections/Contact.astro";
import Footer from "../components/layout/Footer.astro";
import bgCrane from "../assets/images/bg-crane.png";

const optimizedBg = await getImage({ src: bgCrane, format: "webp" });
---

<Layout>
  <Fragment slot="head">
    <link
      rel="preload"
      as="image"
      href={optimizedBg.src}
      fetchpriority="high"
    />
  </Fragment>
  <Navbar />
  <main>
    <Hero />
    <About />
    <Services />
    <Process />
    <WhyUs />
    <Contact />
  </main>
  <Footer />

  <script>
    import "../scripts/reveal.js";
  </script>
</Layout>
